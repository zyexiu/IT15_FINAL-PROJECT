@model SnackFlowMES.Models.BillOfMaterials
@{
    ViewData["Title"] = $"BOM: {Model.Item?.ItemName}";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var showAddLineForm = (TempData["ShowAddLineForm"] as string) == "1";
}

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <p>@TempData["Success"]</p>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--danger">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>@TempData["Error"]</p>
    </div>
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">@Model.Item?.ItemName</h1>
        <p class="dash-page-subtitle">Version @Model.Version • @Model.BatchOutputQty @Model.BatchOutputUom per batch</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        <a asp-action="Edit" asp-route-id="@Model.BomId" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
            Edit BOM
        </a>
        <a asp-action="Index" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back
        </a>
    </div>
</div>

<!-- BOM Header Info -->
<div class="dash-grid" style="margin-bottom: 24px; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
    <div class="dash-card">
        <div class="dash-card-label">BATCH OUTPUT</div>
        <div class="dash-card-value">@Model.BatchOutputQty <span style="font-size: 16px;">@Model.BatchOutputUom</span></div>
    </div>
    <div class="dash-card">
        <div class="dash-card-label">MACHINE HOURS</div>
        <div class="dash-card-value">@(Model.EstMachineHours > 0 ? $"{Model.EstMachineHours:F2}h" : "—")</div>
    </div>
    <div class="dash-card">
        <div class="dash-card-label">LABOR HOURS</div>
        <div class="dash-card-value">@(Model.EstLaborHours > 0 ? $"{Model.EstLaborHours:F2}h" : "—")</div>
    </div>
    <div class="dash-card">
        <div class="dash-card-label">STATUS</div>
        <div>
            @if (Model.IsActive)
            {
                <span class="dash-badge dash-badge--success">Active</span>
            }
            else
            {
                <span class="dash-badge dash-badge--secondary">Inactive</span>
            }
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Notes))
{
    <div class="dash-card" style="margin-bottom: 24px;">
        <h3 class="dash-card-title">Notes</h3>
        <p class="dash-card-text">@Model.Notes</p>
    </div>
}

<!-- Materials Section -->
<div class="dash-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 class="dash-section-title">Materials in BOM</h2>
        <button type="button" class="dash-btn dash-btn--primary" onclick="toggleAddLineForm()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Material
        </button>
    </div>

    <!-- Add Material Form -->
    <form asp-action="AddLine" method="post" id="addLineForm" class="dash-add-form" style="display: @(showAddLineForm ? "block" : "none");">
        @Html.AntiForgeryToken()
        <input type="hidden" name="BomId" value="@Model.BomId" />

        <h3 class="dash-form-title">Add Material to BOM</h3>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label for="itemId" class="dash-label dash-label--required">Raw Material</label>
                <select name="ItemId" id="itemId" class="dash-select" required>
                    <option value="">-- Select Material --</option>
                    @{ var rawMaterials = ViewBag.RawMaterials as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>(); }
                    @foreach (var item in rawMaterials)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
            </div>

            <div class="dash-form-group">
                <label for="quantity" class="dash-label dash-label--required">Quantity</label>
                <input type="number" id="quantity" name="Quantity" class="dash-input" step="0.01" min="0.01" placeholder="0.00" required />
            </div>
        </div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label for="uom" class="dash-label dash-label--required">Unit of Measure</label>
                <select name="UnitOfMeasure" id="uom" class="dash-select" required>
                    <option value="">-- Select Unit --</option>
                    <option value="kg">kg</option>
                    <option value="g">g</option>
                    <option value="L">L</option>
                    <option value="pcs">pcs</option>
                    <option value="bag">bag</option>
                    <option value="box">box</option>
                    <option value="pack">pack</option>
                </select>
            </div>

            <div class="dash-form-group">
                <label for="notes" class="dash-label">Notes</label>
                <input type="text" id="notes" name="Notes" class="dash-input" placeholder="Optional notes..." maxlength="300" />
            </div>
        </div>

        <div style="display: flex; gap: 8px;">
            <button type="submit" class="dash-btn dash-btn--primary">Add Material</button>
            <button type="button" class="dash-btn dash-btn--secondary" onclick="hideAddLineForm()">Cancel</button>
        </div>
    </form>

    @if (Model.BomLines == null || !Model.BomLines.Any())
    {
        <div style="padding: 40px 20px; text-align: center; color: #6B7A8D;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 16px; opacity: 0.5;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="13" x2="12" y2="17"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
            <p style="margin: 0; font-size: 14px;">No materials added yet. Click "Add Material" to get started.</p>
        </div>
    }
    else
    {
        <div class="dash-table-container">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Material</th>
                        <th>Quantity</th>
                        <th>Unit</th>
                        <th>Notes</th>
                        <th style="width: 60px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.BomLines!)
                    {
                        <tr>
                            <td><strong>@line.Item?.ItemName</strong></td>
                            <td>@line.QtyPerBatch</td>
                            <td>@line.UnitOfMeasure</td>
                            <td>@(string.IsNullOrEmpty(line.Notes) ? "—" : line.Notes)</td>
                            <td>
                                <form asp-action="RemoveLine" asp-route-id="@line.BomLineId" method="post" style="display: inline;" onsubmit="return confirm('Remove this material?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dash-btn dash-btn--sm dash-btn--danger" title="Remove material">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
.dash-grid {
    display: grid;
}

.dash-card-label {
    font-size: 12px;
    color: #6B7A8D;
    font-weight: 600;
    margin-bottom: 4px;
}

.dash-card-value {
    font-size: 24px;
    font-weight: 700;
    color: #0F1C26;
}

.dash-card-title {
    margin: 0 0 8px 0;
    font-size: 14px;
    font-weight: 700;
    color: #0F1C26;
}

.dash-card-text {
    margin: 0;
    color: #6B7A8D;
    line-height: 1.6;
}

.dash-section-title {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: #0F1C26;
}

.dash-add-form {
    margin-bottom: 24px;
    padding: 20px;
    background: #F9FAFB;
    border-radius: 8px;
    border: 1px solid #E4E9EF;
}

.dash-form-title {
    margin: 0 0 16px 0;
    font-size: 14px;
    font-weight: 700;
    color: #0F1C26;
}

.dash-table-container {
    background: white;
    border-radius: 12px;
    border: 1px solid #E4E9EF;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(15, 28, 38, 0.05);
}

.dash-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
}

.dash-table thead {
    background: #F9FAFB;
    border-bottom: 1px solid #E4E9EF;
}

.dash-table th {
    padding: 12px 16px;
    text-align: left;
    font-weight: 700;
    color: #0F1C26;
}

.dash-table td {
    padding: 12px 16px;
    border-bottom: 1px solid #E4E9EF;
    color: #4B5563;
}

.dash-table tbody tr:hover {
    background: #F9FAFB;
}

.dash-badge {
    display: inline-block;
    padding: 4px 8px;
    background: #E0E7FF;
    color: #3730A3;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
}

.dash-badge--success {
    background: #D1FAE5;
    color: #065F46;
}

.dash-badge--secondary {
    background: #E5E7EB;
    color: #374151;
}

.dash-btn--danger {
    background: #FEE2E2;
    color: #991B1B;
    border: 1px solid #FECACA;
}

.dash-btn--danger:hover {
    background: #FCA5A5;
    border-color: #F87171;
}

/* Dark Mode Styles */
html[data-theme="dark"] .dash-card-label {
    color: #94a3b8;
}

html[data-theme="dark"] .dash-card-value {
    color: #e5eef8;
}

html[data-theme="dark"] .dash-card-title {
    color: #e5eef8;
}

html[data-theme="dark"] .dash-card-text {
    color: #94a3b8;
}

html[data-theme="dark"] .dash-section-title {
    color: #e5eef8;
}

html[data-theme="dark"] .dash-add-form {
    background: #0f1419 !important;
    border-color: #2d3748 !important;
}

html[data-theme="dark"] .dash-form-title {
    color: #e5eef8 !important;
}

html[data-theme="dark"] .dash-table-container {
    background: #1a2332;
    border-color: #2d3748;
}

html[data-theme="dark"] .dash-table thead {
    background: #0f1419;
    border-color: #2d3748;
}

html[data-theme="dark"] .dash-table th {
    color: #e5eef8;
}

html[data-theme="dark"] .dash-table td {
    border-color: #2d3748;
    color: #cbd5e0;
}

html[data-theme="dark"] .dash-table tbody tr:hover {
    background: #0f1419;
}

html[data-theme="dark"] .dash-badge--secondary {
    background: #2d3748;
    color: #cbd5e0;
}
</style>

<script>
function toggleAddLineForm() {
    const form = document.getElementById('addLineForm');
    if (!form) return;
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
}

function hideAddLineForm() {
    const form = document.getElementById('addLineForm');
    if (!form) return;
    form.style.display = 'none';
}
</script>
