@model SnackFlowMES.ViewModels.BomFormViewModel
@{
    ViewData["Title"] = "Create Bill of Materials";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Create Bill of Materials</h1>
        <p class="dash-page-subtitle">Define the materials and resources needed for a finished good</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        <a asp-action="Index" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to List
        </a>
    </div>
</div>

<div class="dash-card">
    <form asp-action="Create" method="post" style="padding:28px;" id="bomForm" novalidate>
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="dash-alert dash-alert--error" style="margin-bottom:24px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div>
                    <strong>Please correct the following errors:</strong>
                    <ul style="margin:8px 0 0 16px;padding:0;">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- BOM Information -->
        <div class="wo-section-label">BOM Information</div>
        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ItemId" class="dash-label dash-label--required">Finished Good</label>
                <select asp-for="ItemId" asp-items="ViewBag.FinishedGoods" class="dash-select" required>
                    <option value="">-- Select Finished Good --</option>
                </select>
                <span asp-validation-for="ItemId" class="dash-error"></span>
                <small class="dash-hint">Choose the product this BOM will define</small>
            </div>
            <div class="dash-form-group">
                <label asp-for="Version" class="dash-label dash-label--required">Version</label>
                <input asp-for="Version" class="dash-input" placeholder="e.g., v1, v2" required maxlength="10" />
                <span asp-validation-for="Version" class="dash-error"></span>
                <small class="dash-hint">Version identifier (e.g., v1, v2)</small>
            </div>
        </div>

        <!-- Batch Output & Resources -->
        <div class="wo-section-label">Batch Output &amp; Resources</div>
        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="BatchOutputQty" class="dash-label dash-label--required">Batch Output Quantity</label>
                <input asp-for="BatchOutputQty" class="dash-input" type="number" step="0.01" min="0.01" placeholder="0.00" required />
                <span asp-validation-for="BatchOutputQty" class="dash-error"></span>
                <small class="dash-hint">Standard output per batch</small>
            </div>
            <div class="dash-form-group">
                <label asp-for="BatchOutputUom" class="dash-label dash-label--required">Unit of Measure</label>
                <select asp-for="BatchOutputUom" class="dash-select" required>
                    <option value="">-- Select Unit --</option>
                    <option value="kg">kg</option>
                    <option value="g">g</option>
                    <option value="L">L</option>
                    <option value="pcs">pcs</option>
                    <option value="bag">bag</option>
                    <option value="box">box</option>
                    <option value="pack">pack</option>
                </select>
                <span asp-validation-for="BatchOutputUom" class="dash-error"></span>
            </div>
        </div>
        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="EstMachineHours" class="dash-label">Est. Machine Hours</label>
                <input asp-for="EstMachineHours" class="dash-input" type="number" step="0.01" min="0" placeholder="0.00" />
                <span asp-validation-for="EstMachineHours" class="dash-error"></span>
                <small class="dash-hint">Estimated machine hours per batch (optional)</small>
            </div>
            <div class="dash-form-group">
                <label asp-for="EstLaborHours" class="dash-label">Est. Labor Hours</label>
                <input asp-for="EstLaborHours" class="dash-input" type="number" step="0.01" min="0" placeholder="0.00" />
                <span asp-validation-for="EstLaborHours" class="dash-error"></span>
                <small class="dash-hint">Estimated labor hours per batch (optional)</small>
            </div>
        </div>

        <!-- Status -->
        <div class="wo-section-label">Status</div>
        <div class="dash-form-group">
            <label class="dash-checkbox-label">
                <input asp-for="IsActive" type="checkbox" style="width:16px;height:16px;accent-color:#3B82F6;cursor:pointer;" />
                <span style="font-size:0.9375rem;font-weight:500;color:var(--text-primary);">Active BOM (can be used for work orders)</span>
            </label>
            <small class="dash-hint" style="margin-top:4px;">Uncheck to archive this BOM</small>
        </div>

        <!-- Additional Information -->
        <div class="wo-section-label">Additional Information</div>
        <div class="dash-form-group">
            <label asp-for="Notes" class="dash-label">Notes</label>
            <textarea asp-for="Notes" class="dash-textarea" rows="3" placeholder="Add any special instructions or notes..."></textarea>
            <span asp-validation-for="Notes" class="dash-error"></span>
        </div>

        <!-- Actions -->
        <div style="display:flex;gap:12px;margin-top:32px;padding-top:24px;border-top:1px solid var(--border-color);">
            <button type="submit" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Create BOM
            </button>
            <a asp-action="Index" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

<style>
.wo-section-label {
    font-size: 0.8125rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.6px; color: var(--text-secondary);
    padding-bottom: 12px; margin: 24px 0 4px 0;
    border-bottom: 1px solid var(--border-color);
}
.wo-section-label:first-of-type { margin-top: 0; }
.dash-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.dash-form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
.dash-label { font-size: 0.875rem; font-weight: 600; color: var(--text-primary); }
.dash-label--required::after { content: ' *'; color: #EF4444; }
.dash-checkbox-label { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.dash-input, .dash-select, .dash-textarea {
    padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px;
    font-size: 0.9375rem; color: var(--text-primary); background: var(--bg-primary);
    transition: border-color 0.2s, box-shadow 0.2s; width: 100%;
}
.dash-input:focus, .dash-select:focus, .dash-textarea:focus {
    outline: none; border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
}
.dash-textarea { resize: vertical; min-height: 80px; }
.dash-hint { font-size: 0.8125rem; color: var(--text-secondary); }
.dash-error { font-size: 0.8125rem; color: #EF4444; font-weight: 500; }
@@media (max-width: 768px) { .dash-form-row { grid-template-columns: 1fr; } }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('bomForm');
            if (form) {
                form.addEventListener('submit', function (e) {
                    const itemId  = document.querySelector('[name="ItemId"]');
                    const version = document.querySelector('[name="Version"]');
                    const qty     = document.querySelector('[name="BatchOutputQty"]');
                    const uom     = document.querySelector('[name="BatchOutputUom"]');
                    const errors  = [];
                    if (!itemId.value)  errors.push('Please select a Finished Good.');
                    if (!version.value) errors.push('Version is required.');
                    if (!qty.value || parseFloat(qty.value) <= 0) errors.push('Batch Output Quantity must be greater than 0.');
                    if (!uom.value)     errors.push('Unit of Measure is required.');
                    if (errors.length > 0) { e.preventDefault(); alert('Please fix:\n\n' + errors.join('\n')); }
                });
            }
        });
    </script>
}
