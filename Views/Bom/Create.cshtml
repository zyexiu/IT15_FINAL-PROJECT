@model SnackFlowMES.ViewModels.BomFormViewModel
@{
    ViewData["Title"] = "Create Bill of Materials";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Create Bill of Materials</h1>
        <p class="dash-page-subtitle">Define the materials and resources needed for a finished good</p>
    </div>
    <a asp-action="Index" class="dash-btn dash-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to List
    </a>
</div>

<div class="dash-card">
    <form asp-action="Create" method="post" class="dash-form" id="bomForm" novalidate>
        @Html.AntiForgeryToken()
        
        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="dash-alert dash-alert--error">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div>
                    <strong>Please correct the following errors:</strong>
                    <ul>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- Section 1: BOM Header -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">BOM Information</legend>
            
            <div class="dash-form-row">
                <div class="dash-form-group">
                    <label asp-for="ItemId" class="dash-label dash-label--required"></label>
                    <select asp-for="ItemId" asp-items="ViewBag.FinishedGoods" class="dash-select" required>
                        <option value="">-- Select Finished Good --</option>
                    </select>
                    <span asp-validation-for="ItemId" class="dash-error"></span>
                    <span class="dash-form-hint">Choose the product this BOM will define</span>
                </div>

                <div class="dash-form-group">
                    <label asp-for="Version" class="dash-label dash-label--required"></label>
                    <input asp-for="Version" class="dash-input" placeholder="e.g., v1, v2" required maxlength="10" />
                    <span asp-validation-for="Version" class="dash-error"></span>
                    <span class="dash-form-hint">Version identifier (e.g., v1, v2)</span>
                </div>
            </div>
        </fieldset>

        <!-- Section 2: Output & Resources -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">Batch Output & Resources</legend>
            
            <div class="dash-form-row">
                <div class="dash-form-group">
                    <label asp-for="BatchOutputQty" class="dash-label dash-label--required"></label>
                    <input asp-for="BatchOutputQty" class="dash-input" type="number" step="0.01" min="0.01" placeholder="0.00" required />
                    <span asp-validation-for="BatchOutputQty" class="dash-error"></span>
                    <span class="dash-form-hint">Standard output per batch</span>
                </div>

                <div class="dash-form-group">
                    <label asp-for="BatchOutputUom" class="dash-label dash-label--required"></label>
                    <select asp-for="BatchOutputUom" class="dash-select" required>
                        <option value="">-- Select Unit --</option>
                        <option value="kg">kg</option>
                        <option value="g">g</option>
                        <option value="L">L</option>
                        <option value="pcs">pcs</option>
                        <option value="bag">bag</option>
                        <option value="box">box</option>
                        <option value="pack">pack</option>
                    </select>
                    <span asp-validation-for="BatchOutputUom" class="dash-error"></span>
                </div>
            </div>

            <div class="dash-form-row">
                <div class="dash-form-group">
                    <label asp-for="EstMachineHours" class="dash-label"></label>
                    <input asp-for="EstMachineHours" class="dash-input" type="number" step="0.01" min="0" />
                    <span asp-validation-for="EstMachineHours" class="dash-error"></span>
                    <span class="dash-form-hint">Estimated machine hours per batch (optional)</span>
                </div>

                <div class="dash-form-group">
                    <label asp-for="EstLaborHours" class="dash-label"></label>
                    <input asp-for="EstLaborHours" class="dash-input" type="number" step="0.01" min="0" />
                    <span asp-validation-for="EstLaborHours" class="dash-error"></span>
                    <span class="dash-form-hint">Estimated labor hours per batch (optional)</span>
                </div>
            </div>
        </fieldset>

        <!-- Section 3: Status -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">Status</legend>
            
            <div class="dash-form-group">
                <label class="dash-checkbox">
                    <input asp-for="IsActive" type="checkbox" />
                    <span>Active BOM (can be used for work orders)</span>
                </label>
                <span class="dash-form-hint">Uncheck to archive this BOM</span>
            </div>
        </fieldset>

        <!-- Section 4: Notes -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">Additional Information</legend>
            
            <div class="dash-form-group">
                <label asp-for="Notes" class="dash-label"></label>
                <textarea asp-for="Notes" class="dash-textarea" rows="3" placeholder="Add any special instructions or notes..."></textarea>
                <span asp-validation-for="Notes" class="dash-error"></span>
            </div>
        </fieldset>

        <!-- Form Actions -->
        <div class="dash-form-actions">
            <button type="submit" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Create BOM
            </button>
            <a asp-action="Index" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('bomForm');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const itemId = document.querySelector('[name="ItemId"]');
                    const version = document.querySelector('[name="Version"]');
                    const batchQty = document.querySelector('[name="BatchOutputQty"]');
                    const batchUom = document.querySelector('[name="BatchOutputUom"]');

                    let errors = [];
                    if (!itemId.value) errors.push('Please select a Finished Good');
                    if (!version.value) errors.push('Version is required');
                    if (!batchQty.value || parseFloat(batchQty.value) <= 0) errors.push('Batch Output Quantity must be greater than 0');
                    if (!batchUom.value) errors.push('Unit of Measure is required');

                    if (errors.length > 0) {
                        e.preventDefault();
                        alert('Please fix the following errors:\n\n' + errors.join('\n'));
                    }
                });
            }
        });
    </script>
}
