@model SnackFlowMES.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Manager Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var openDowntime = ViewBag.OpenDowntimeCount as int? ?? 0;
}

<div class="dash-role-welcome">
    <div class="dash-role-welcome-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
    </div>
    <div class="dash-role-welcome-content">
        <h1 class="dash-role-welcome-title">Business Analytics</h1>
        <p class="dash-role-welcome-subtitle">Your role focuses on monitoring operations and business performance, not production execution or system administration. Track KPIs and analyze production metrics.</p>
    </div>
</div>

<div class="dash-kpi-grid">
    <div class="dash-kpi-card dash-kpi-role-manager">
        <div class="dash-kpi-icon dash-kpi-icon--blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Total Work Orders</span>
            <span class="dash-kpi-value">@Model.TotalWorkOrders</span>
            <span class="dash-kpi-sub">All time</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-manager">
        <div class="dash-kpi-icon dash-kpi-icon--amber" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Active Production</span>
            <span class="dash-kpi-value">@Model.ActiveProduction</span>
            <span class="dash-kpi-sub">Released + In Progress</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-manager">
        <div class="dash-kpi-icon dash-kpi-icon--green" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Completed Orders</span>
            <span class="dash-kpi-value">@Model.CompletedOrders</span>
            <span class="dash-kpi-sub">Successfully closed</span>
        </div>
    </div>

    @if (openDowntime > 0)
    {
        <div class="dash-kpi-card dash-kpi-card--alert dash-kpi-role-manager">
            <div class="dash-kpi-icon dash-kpi-icon--orange" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div class="dash-kpi-body">
                <span class="dash-kpi-label">Open Downtime</span>
                <span class="dash-kpi-value">@openDowntime</span>
                <span class="dash-kpi-sub">Requires resolution</span>
            </div>
            <a href="/Downtime?status=Open" class="dash-kpi-link">View Reports →</a>
        </div>
    }
</div>

<div class="dash-row dash-manager-analytics-row">
    <div class="dash-panel dash-panel--wide dash-manager-chart-panel">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                Completion Rate Performance
            </h2>
            <span class="dash-panel-subtitle">Status percentages across all work orders</span>
        </div>

        <div class="dash-manager-chart-wrap">
            <canvas id="completionRateChart"></canvas>
        </div>

        <div class="dash-summary-box dash-manager-summary-box">
            <div class="dash-summary-row">
                <span>Total Orders</span>
                <strong>@Model.TotalWorkOrders</strong>
            </div>
            <div class="dash-summary-row">
                <span>Completed Rate</span>
                <strong>@(Model.TotalWorkOrders > 0 ? $"{(Model.CompletedOrders * 100.0 / Model.TotalWorkOrders):F0}%" : "—")</strong>
            </div>
            <div class="dash-summary-row">
                <span>Active Now</span>
                <strong class="dash-summary-active">@Model.ActiveProduction</strong>
            </div>
        </div>
    </div>

    <div class="dash-panel dash-panel--narrow dash-manager-status-panel">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                Order Status
            </h2>
        </div>

        <div class="dash-status-list">
            <div class="dash-status-row">
                <div class="dash-status-dot dash-status-dot--draft"></div>
                <span class="dash-status-label">Draft</span>
                <span class="dash-status-count">@Model.DraftCount</span>
                <div class="dash-status-bar-track">
                    <div class="dash-status-bar dash-status-bar--draft" style="width:@(Model.TotalWorkOrders > 0 ? (Model.DraftCount * 100 / Model.TotalWorkOrders) : 0)%"></div>
                </div>
            </div>
            <div class="dash-status-row">
                <div class="dash-status-dot dash-status-dot--released"></div>
                <span class="dash-status-label">Released</span>
                <span class="dash-status-count">@Model.ReleasedCount</span>
                <div class="dash-status-bar-track">
                    <div class="dash-status-bar dash-status-bar--released" style="width:@(Model.TotalWorkOrders > 0 ? (Model.ReleasedCount * 100 / Model.TotalWorkOrders) : 0)%"></div>
                </div>
            </div>
            <div class="dash-status-row">
                <div class="dash-status-dot dash-status-dot--inprogress"></div>
                <span class="dash-status-label">In Progress</span>
                <span class="dash-status-count">@Model.InProgressCount</span>
                <div class="dash-status-bar-track">
                    <div class="dash-status-bar dash-status-bar--inprogress" style="width:@(Model.TotalWorkOrders > 0 ? (Model.InProgressCount * 100 / Model.TotalWorkOrders) : 0)%"></div>
                </div>
            </div>
            <div class="dash-status-row">
                <div class="dash-status-dot dash-status-dot--completed"></div>
                <span class="dash-status-label">Completed</span>
                <span class="dash-status-count">@Model.CompletedCount</span>
                <div class="dash-status-bar-track">
                    <div class="dash-status-bar dash-status-bar--completed" style="width:@(Model.TotalWorkOrders > 0 ? (Model.CompletedCount * 100 / Model.TotalWorkOrders) : 0)%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="dash-row">
    <div class="dash-panel dash-panel--wide">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Production Overview
            </h2>
            <a href="/WorkOrder" class="dash-panel-action">View all →</a>
        </div>

        @if (!Model.RecentWorkOrders.Any())
        {
            <div class="dash-empty">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <p>No work orders yet.</p>
            </div>
        }
        else
        {
            <div class="dash-table-wrap">
                <table class="dash-table" role="table">
                    <thead>
                        <tr>
                            <th>WO Number</th>
                            <th>Product</th>
                            <th>Line</th>
                            <th>Planned Qty</th>
                            <th>Actual Qty</th>
                            <th>Efficiency</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wo in Model.RecentWorkOrders)
                        {
                            var efficiency = wo.PlannedQty > 0 ? (wo.ActualQty / wo.PlannedQty * 100) : 0;
                            <tr>
                                <td class="dash-table-mono"><a href="/WorkOrder/Details/@wo.WorkOrderId">@wo.WoNumber</a></td>
                                <td class="dash-table-primary">@wo.ItemName</td>
                                <td>@(wo.ProductionLine ?? "—")</td>
                                <td>@wo.PlannedQty.ToString("N0") @wo.UnitOfMeasure</td>
                                <td>@wo.ActualQty.ToString("N0") @wo.UnitOfMeasure</td>
                                <td>
                                    <span style="color:@(efficiency >= 90 ? "#10B981" : efficiency >= 70 ? "#F59E0B" : "#EF4444");font-weight:600;">
                                        @efficiency.ToString("F0")%
                                    </span>
                                </td>
                                <td>
                                    <span class="dash-badge dash-badge--@wo.Status.ToLower()">@wo.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
.dash-manager-analytics-row {
    display: flex;
    gap: 20px;
    align-items: stretch;
}

.dash-manager-chart-panel {
    min-width: 0;
    flex: 2.2;
}

.dash-manager-status-panel {
    min-width: 0;
    flex: 1;
}

.dash-manager-chart-wrap {
    position: relative;
    width: 100%;
    height: 380px;
    margin-bottom: 18px;
}

.dash-manager-summary-box {
    margin-top: 0;
}

@@media (max-width: 1100px) {
    .dash-manager-analytics-row {
        flex-direction: column;
    }

    .dash-manager-chart-wrap {
        height: 320px;
    }
}

@@media (max-width: 768px) {
    .dash-manager-chart-wrap {
        height: 280px;
    }
}

@@media (max-width: 480px) {
    .dash-manager-chart-wrap {
        height: 240px;
    }
}
</style>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (!window.Chart) return;

        Chart.defaults.font.family = 'Inter, sans-serif';
        Chart.defaults.color = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim();

        const completionCtx = document.getElementById('completionRateChart');
        if (!completionCtx) return;

        const total = @Model.TotalWorkOrders;
        const statusPercentages = total > 0
            ? [
                (@Model.DraftCount * 100 / @Model.TotalWorkOrders),
                (@Model.ReleasedCount * 100 / @Model.TotalWorkOrders),
                (@Model.InProgressCount * 100 / @Model.TotalWorkOrders),
                (@Model.CompletedCount * 100 / @Model.TotalWorkOrders)
              ]
            : [0, 0, 0, 0];

        new Chart(completionCtx, {
            type: 'line',
            data: {
                labels: ['Draft', 'Released', 'In Progress', 'Completed'],
                datasets: [{
                    label: 'Status %',
                    data: statusPercentages,
                    borderColor: '#3B82F6',
                    backgroundColor: 'rgba(59, 130, 246, 0.12)',
                    fill: true,
                    tension: 0.35,
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    pointBackgroundColor: '#3B82F6',
                    pointBorderColor: '#FFFFFF',
                    pointBorderWidth: 2,
                    borderWidth: 3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(0, 0, 0, 0.8)',
                        padding: 12,
                        titleFont: { size: 14, weight: '600' },
                        bodyFont: { size: 13 },
                        callbacks: {
                            label: function (context) {
                                return context.parsed.y.toFixed(0) + '%';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        suggestedMax: 100,
                        ticks: { callback: function (value) { return value + '%'; } },
                        grid: { color: 'rgba(255,255,255,0.05)' }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    });
</script>
}