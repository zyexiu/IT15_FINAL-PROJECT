@model SnackFlowMES.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Operator Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Role Welcome Banner -->
<div class="dash-role-welcome">
    <div class="dash-role-welcome-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 6v6"/></svg>
    </div>
    <div class="dash-role-welcome-content">
        <h1 class="dash-role-welcome-title">Production Floor</h1>
        <p class="dash-role-welcome-subtitle">Execute production operations, record production logs, and update work order progress. Your role focuses on floor execution, not planning or administration.</p>
    </div>
</div>

<!-- Quick Actions removed for Operator dashboard (redundant) -->

<!-- ══ KPI CARDS ════════════════════════════════════════════ -->
<div class="dash-kpi-grid">
    <div class="dash-kpi-card dash-kpi-role-operator">
        <div class="dash-kpi-icon dash-kpi-icon--blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Released Orders</span>
            <span class="dash-kpi-value">@Model.ReleasedCount</span>
            <span class="dash-kpi-sub">Ready to start</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-operator">
        <div class="dash-kpi-icon dash-kpi-icon--amber" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">In Progress</span>
            <span class="dash-kpi-value">@Model.InProgressCount</span>
            <span class="dash-kpi-sub">Active now</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-operator">
        <div class="dash-kpi-icon dash-kpi-icon--green" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Completed Today</span>
            <span class="dash-kpi-value">@Model.CompletedCount</span>
            <span class="dash-kpi-sub">This shift</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-operator">
        <div class="dash-kpi-icon dash-kpi-icon--purple" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Production Efficiency</span>
            <span class="dash-kpi-value">
                @{
                    var totalPlanned = Model.RecentWorkOrders.Sum(w => w.PlannedQty);
                    var totalActual = Model.RecentWorkOrders.Sum(w => w.ActualQty);
                    var efficiency = totalPlanned > 0 ? (totalActual / totalPlanned * 100m) : 0m;
                }
                @efficiency.ToString("F0")%
            </span>
            <span class="dash-kpi-sub">Overall performance</span>
        </div>
    </div>
</div>

<!-- ══ OPERATOR ANALYTICS ═══════════════════════════════════ -->
<div class="dash-row">
    <div class="dash-panel dash-panel--wide dash-operator-chart-panel">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                Work orders by day
            </h2>
            <span class="dash-chart-subtitle">Stacked bars: new orders each day by current status · Auto-refresh</span>
        </div>

        <div class="dash-operator-chart-wrap" role="img" aria-label="Work orders created in the last fourteen days by status">
            <canvas id="operatorStatusTrendChart"></canvas>
        </div>
    </div>
</div>

<!-- ══ MAIN CONTENT ROW ══════════════════════════════════════ -->
<div class="dash-row">
    <!-- My Work Orders -->
    <div class="dash-panel dash-panel--wide">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                My Work Orders
            </h2>
            <a href="/WorkOrder" class="dash-panel-action">View all →</a>
        </div>

        @if (!Model.RecentWorkOrders.Any())
        {
            <div class="dash-empty">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <p>No work orders assigned yet.</p>
            </div>
        }
        else
        {
            <div class="dash-table-wrap">
                <table class="dash-table" role="table">
                    <thead>
                        <tr>
                            <th>WO Number</th>
                            <th>Product</th>
                            <th>Line</th>
                            <th>Planned Qty</th>
                            <th>Actual Qty</th>
                            <th>Progress</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wo in Model.RecentWorkOrders.Where(w => w.Status == "Released" || w.Status == "InProgress").Take(10))
                        {
                            var progress = wo.PlannedQty > 0 ? (wo.ActualQty / wo.PlannedQty * 100) : 0;
                            <tr>
                                <td class="dash-table-mono"><a href="/WorkOrder/Details/@wo.WorkOrderId">@wo.WoNumber</a></td>
                                <td class="dash-table-primary">@wo.ItemName</td>
                                <td>@(wo.ProductionLine ?? "—")</td>
                                <td>@wo.PlannedQty.ToString("N0") @wo.UnitOfMeasure</td>
                                <td>@wo.ActualQty.ToString("N0") @wo.UnitOfMeasure</td>
                                <td>
                                    <div class="dash-progress-bar">
                                        <div class="dash-progress-fill" style="width:@Math.Min(progress, 100)%;background:@(progress >= 100 ? "#10B981" : progress >= 50 ? "#3B82F6" : "#F59E0B");"></div>
                                    </div>
                                    <span class="dash-progress-text">@progress.ToString("F0")%</span>
                                </td>
                                <td>
                                    <span class="dash-badge dash-badge--@wo.Status.ToLower()">
                                        @wo.Status
                                    </span>
                                </td>
                                <td>
                                    <a href="/WorkOrder/Details/@wo.WorkOrderId" class="dash-action-btn" title="View Details">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Quick Guide removed per request; keep layout consistent -->
</div>

<style>
.dash-progress-bar {
    width: 100%;
    height: 8px;
    background: var(--bg-secondary);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 4px;
}

.dash-progress-fill {
    height: 100%;
    transition: width 0.3s ease;
}

.dash-progress-text {
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-weight: 600;
}

.dash-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: var(--bg-primary);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.2s;
}

.dash-action-btn:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border-color: var(--text-secondary);
}

.dash-operator-chart-panel {
    padding-bottom: 18px;
}

.dash-chart-subtitle {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    font-weight: 500;
}

.dash-operator-chart-wrap {
    position: relative;
    height: clamp(260px, 42vw, 360px);
    min-height: 240px;
    width: 100%;
    max-width: 100%;
    margin-top: 8px;
    padding: clamp(8px, 2vw, 14px);
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: linear-gradient(180deg, rgba(99, 102, 241, 0.06) 0%, rgba(99, 102, 241, 0.02) 100%);
}

@@media (max-width: 992px) {
    .dash-operator-chart-wrap {
        height: clamp(240px, 55vw, 320px);
        min-height: 220px;
        padding: 10px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var canvas = document.getElementById('operatorStatusTrendChart');
    if (!canvas || typeof Chart === 'undefined') return;

    var pollMs = 15000;
    var chartUrl = '@Url.Action("OperatorChartData", "Dashboard")';

    function themeColors() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        return {
            tickColor: isDark ? '#B0BEC5' : '#6B7280',
            gridColor: isDark ? 'rgba(148, 163, 184, 0.22)' : 'rgba(148, 163, 184, 0.25)'
        };
    }

    function rowsToDatasetArrays(rows) {
        return {
            labels: rows.map(function(r) { return r.date; }),
            draft: rows.map(function(r) { return r.draft; }),
            released: rows.map(function(r) { return r.released; }),
            inProgress: rows.map(function(r) { return r.inProgress; }),
            completed: rows.map(function(r) { return r.completed; }),
            cancelled: rows.map(function(r) { return r.cancelled; })
        };
    }

    function buildDatasets(arr) {
        return [
            {
                label: 'Draft',
                data: arr.draft,
                backgroundColor: 'rgba(148, 163, 184, 0.9)',
                borderColor: '#64748B',
                borderWidth: 1
            },
            {
                label: 'Released',
                data: arr.released,
                backgroundColor: 'rgba(59, 130, 246, 0.9)',
                borderColor: '#2563EB',
                borderWidth: 1
            },
            {
                label: 'In Progress',
                data: arr.inProgress,
                backgroundColor: 'rgba(245, 158, 11, 0.9)',
                borderColor: '#D97706',
                borderWidth: 1
            },
            {
                label: 'Completed',
                data: arr.completed,
                backgroundColor: 'rgba(16, 185, 129, 0.9)',
                borderColor: '#059669',
                borderWidth: 1
            },
            {
                label: 'Cancelled',
                data: arr.cancelled,
                backgroundColor: 'rgba(100, 116, 139, 0.75)',
                borderColor: '#475569',
                borderWidth: 1
            }
        ];
    }

    function applyChartColors(chart, colors) {
        var opts = chart && chart.options;
        if (!opts) return;
        var plugins = opts.plugins;
        if (plugins && plugins.legend && plugins.legend.labels)
            plugins.legend.labels.color = colors.tickColor;
        var sx = opts.scales && opts.scales.x;
        var sy = opts.scales && opts.scales.y;
        if (sx && sx.ticks) sx.ticks.color = colors.tickColor;
        if (sy && sy.ticks) sy.ticks.color = colors.tickColor;
        if (sx && sx.grid) sx.grid.color = colors.gridColor;
        if (sy && sy.grid) sy.grid.color = colors.gridColor;
    }

    var initialRows = @Html.Raw(ViewBag.OperatorDailyStatusTrend as string ?? "[]");
    var first = rowsToDatasetArrays(initialRows);
    var colors0 = themeColors();
    var ctx = canvas.getContext('2d');

    var chart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: first.labels,
            datasets: buildDatasets(first)
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            resizeDelay: 50,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: {
                    display: true,
                    position: 'top',
                    labels: {
                        color: colors0.tickColor,
                        usePointStyle: true,
                        boxWidth: 10,
                        boxHeight: 10,
                        padding: 12,
                        font: { size: 11, weight: '600' }
                    }
                },
                tooltip: {
                    mode: 'index',
                    intersect: false,
                    callbacks: {
                        footer: function(items) {
                            if (!items.length) return '';
                            var i = items[0].dataIndex;
                            var t = 0;
                            items.forEach(function(it) { t += it.parsed.y || 0; });
                            return 'Day total: ' + t;
                        }
                    }
                }
            },
            scales: {
                x: {
                    stacked: true,
                    ticks: {
                        color: colors0.tickColor,
                        maxRotation: 45,
                        minRotation: 0,
                        autoSkip: true,
                        maxTicksLimit: 14,
                        font: { size: 10 }
                    },
                    grid: { display: false, drawBorder: false }
                },
                y: {
                    stacked: true,
                    beginAtZero: true,
                    ticks: {
                        color: colors0.tickColor,
                        precision: 0,
                        stepSize: 1
                    },
                    grid: { color: colors0.gridColor, drawBorder: false }
                }
            }
        }
    });

    async function refreshFromServer() {
        try {
            var sep = chartUrl.indexOf('?') >= 0 ? '&' : '?';
            var res = await fetch(chartUrl + sep + '_=' + Date.now(), {
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
            });
            if (!res.ok) return;
            var rows = await res.json();
            if (!Array.isArray(rows) || !rows.length) return;

            var next = rowsToDatasetArrays(rows);
            var c = themeColors();
            chart.data.labels = next.labels;
            for (var d = 0; d < chart.data.datasets.length; d++) {
                var key = ['draft', 'released', 'inProgress', 'completed', 'cancelled'][d];
                chart.data.datasets[d].data = next[key];
            }
            applyChartColors(chart, c);
            chart.update();
        } catch (e) { /* ignore transient network errors */ }
    }

    var pollId = setInterval(refreshFromServer, pollMs);
    window.addEventListener('pagehide', function() { clearInterval(pollId); });

    var themeObserver = new MutationObserver(function() {
        var c = themeColors();
        applyChartColors(chart, c);
        chart.update('none');
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
});
</script>
