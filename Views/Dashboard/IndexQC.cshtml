@model SnackFlowMES.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "QC Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Role Welcome Banner -->
<div class="dash-role-welcome">
    <div class="dash-role-welcome-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <div class="dash-role-welcome-content">
        <h1 class="dash-role-welcome-title">Welcome, Quality Control</h1>
        <p class="dash-role-welcome-subtitle">Review completed work orders, approve outputs, and add quality remarks.</p>
    </div>
</div>

<!-- Quick Actions -->
<div class="dash-quick-actions">
    <a href="/WorkOrder?status=Completed" class="dash-quick-action">
        <div class="dash-quick-action-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="dash-quick-action-content">
            <div class="dash-quick-action-title">Completed Orders</div>
            <div class="dash-quick-action-subtitle">Pending QC review</div>
        </div>
    </a>
    <a href="/WorkOrder?status=InProgress" class="dash-quick-action">
        <div class="dash-quick-action-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="dash-quick-action-content">
            <div class="dash-quick-action-title">In Progress</div>
            <div class="dash-quick-action-subtitle">Monitor production</div>
        </div>
    </a>
</div>

<!-- ══ KPI CARDS ════════════════════════════════════════════ -->
<div class="dash-kpi-grid">
    <div class="dash-kpi-card dash-kpi-role-qc">
        <div class="dash-kpi-icon dash-kpi-icon--green" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Completed Orders</span>
            <span class="dash-kpi-value">@Model.CompletedOrders</span>
            <span class="dash-kpi-sub">Pending QC review</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-qc">
        <div class="dash-kpi-icon dash-kpi-icon--amber" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">In Progress</span>
            <span class="dash-kpi-value">@Model.InProgressCount</span>
            <span class="dash-kpi-sub">Currently in production</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-qc">
        <div class="dash-kpi-icon dash-kpi-icon--blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Total Orders</span>
            <span class="dash-kpi-value">@Model.TotalWorkOrders</span>
            <span class="dash-kpi-sub">All time</span>
        </div>
    </div>
</div>

<!-- ══ COMPLETED WORK ORDERS FOR QC ═════════════════════════ -->
<div class="dash-panel">
    <div class="dash-panel-header">
        <h2 class="dash-panel-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Completed Work Orders - QC Review
        </h2>
        <a href="/WorkOrder?status=Completed" class="dash-panel-action">View all →</a>
    </div>

    @if (!Model.RecentWorkOrders.Any(w => w.Status == "Completed"))
    {
        <div class="dash-empty">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <p>No completed work orders pending QC review.</p>
        </div>
    }
    else
    {
        <div class="dash-table-wrap">
            <table class="dash-table" role="table">
                <thead>
                    <tr>
                        <th>WO Number</th>
                        <th>Product</th>
                        <th>Line</th>
                        <th>Planned Qty</th>
                        <th>Actual Qty</th>
                        <th>Variance</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var wo in Model.RecentWorkOrders.Where(w => w.Status == "Completed"))
                    {
                        var variance = wo.ActualQty - wo.PlannedQty;
                        var variancePercent = wo.PlannedQty > 0 ? (variance / wo.PlannedQty * 100) : 0;
                        <tr>
                            <td class="dash-table-mono"><a href="/WorkOrder/Details/@wo.WorkOrderId">@wo.WoNumber</a></td>
                            <td class="dash-table-primary">@wo.ItemName</td>
                            <td>@(wo.ProductionLine ?? "—")</td>
                            <td>@wo.PlannedQty.ToString("N0") @wo.UnitOfMeasure</td>
                            <td>@wo.ActualQty.ToString("N0") @wo.UnitOfMeasure</td>
                            <td>
                                <span style="color:@(variance >= 0 ? "#10B981" : "#EF4444");font-weight:600;">
                                    @(variance >= 0 ? "+" : "")@variance.ToString("N0") (@variancePercent.ToString("F1")%)
                                </span>
                            </td>
                            <td>
                                <span class="dash-badge dash-badge--completed">
                                    @wo.Status
                                </span>
                            </td>
                            <td>
                                <a href="/WorkOrder/Details/@wo.WorkOrderId" class="dash-btn dash-btn--secondary dash-btn--sm">Review</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
