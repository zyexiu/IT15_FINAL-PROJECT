@model SnackFlowMES.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Planner Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Role Welcome Banner -->
<div class="dash-role-welcome">
    <div class="dash-role-welcome-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div>
    <div class="dash-role-welcome-content">
        <h1 class="dash-role-welcome-title">Production Planning</h1>
        <p class="dash-role-welcome-subtitle">Create production plans, schedule work orders, manage BOMs, and optimize manufacturing operations. Your role focuses on planning and scheduling, not floor execution.</p>
    </div>
</div>



<!-- ══ KPI CARDS ════════════════════════════════════════════ -->
<div class="dash-kpi-grid">
    <div class="dash-kpi-card dash-kpi-role-planner">
        <div class="dash-kpi-icon dash-kpi-icon--blue" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Total Work Orders</span>
            <span class="dash-kpi-value">@Model.TotalWorkOrders</span>
            <span class="dash-kpi-sub">All time</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-planner">
        <div class="dash-kpi-icon dash-kpi-icon--amber" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Active Production</span>
            <span class="dash-kpi-value">@Model.ActiveProduction</span>
            <span class="dash-kpi-sub">Released + In Progress</span>
        </div>
    </div>

    <div class="dash-kpi-card dash-kpi-role-planner">
        <div class="dash-kpi-icon dash-kpi-icon--green" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="dash-kpi-body">
            <span class="dash-kpi-label">Completed Orders</span>
            <span class="dash-kpi-value">@Model.CompletedOrders</span>
            <span class="dash-kpi-sub">Successfully closed</span>
        </div>
    </div>
</div>

<!-- ══ ANALYTICS ROW ════════════════════════════════════════ -->
<div class="dash-row">
    <!-- Order Status Analytics -->
    <div class="dash-panel dash-panel--wide">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                Order Status Analytics
            </h2>
        </div>

        <div class="dash-analytics-container">
            <canvas id="orderStatusChart" height="100"></canvas>
        </div>

        <div class="dash-analytics-stats">
            <div class="dash-analytics-stat">
                <span class="dash-analytics-stat-label">Total Orders</span>
                <span class="dash-analytics-stat-value">@Model.TotalWorkOrders</span>
            </div>
            <div class="dash-analytics-stat">
                <span class="dash-analytics-stat-label">Completion Rate</span>
                <span class="dash-analytics-stat-value">
                    @(Model.TotalWorkOrders > 0
                        ? $"{(Model.CompletedOrders * 100.0 / Model.TotalWorkOrders):F0}%"
                        : "—")
                </span>
            </div>
            <div class="dash-analytics-stat">
                <span class="dash-analytics-stat-label">Active Now</span>
                <span class="dash-analytics-stat-value dash-analytics-stat-active">@Model.ActiveProduction</span>
            </div>
        </div>
        @if (!Model.RecentWorkOrders.Any())
        {
            <div class="dash-empty">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <p>No work orders yet. Create your first work order to get started.</p>
            </div>
        }
        else
        {
            <div class="dash-table-wrap">
                <table class="dash-table" role="table">
                    <thead>
                        <tr>
                            <th>WO Number</th>
                            <th>Product</th>
                            <th>Line</th>
                            <th>Planned Qty</th>
                            <th>Actual Qty</th>
                            <th>Scheduled</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wo in Model.RecentWorkOrders)
                        {
                            <tr>
                                <td class="dash-table-mono"><a href="/WorkOrder/Details/@wo.WorkOrderId">@wo.WoNumber</a></td>
                                <td class="dash-table-primary">@wo.ItemName</td>
                                <td>@(wo.ProductionLine ?? "—")</td>
                                <td>@wo.PlannedQty.ToString("N0") @wo.UnitOfMeasure</td>
                                <td>@wo.ActualQty.ToString("N0") @wo.UnitOfMeasure</td>
                                <td>@wo.ScheduledStart.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="dash-badge dash-badge--@wo.Status.ToLower()">
                                        @wo.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
.dash-analytics-container {
    position: relative;
    width: 100%;
    height: 300px;
    margin-bottom: 24px;
    padding: 16px;
    background: var(--bg-secondary);
    border-radius: 12px;
}

.dash-analytics-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding: 28px 0;
    border-top: 1px solid var(--border-color);
}

.dash-analytics-stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: center;
}

.dash-analytics-stat-label {
    font-size: 0.813rem;
    color: var(--text-secondary);
    font-weight: 500;
    letter-spacing: 0.5px;
}

.dash-analytics-stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
}

.dash-analytics-stat-active {
    color: #F59E0B;
}

@@media (max-width: 768px) {
    .dash-analytics-stats {
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        padding: 20px 0;
    }

    .dash-analytics-stat-value {
        font-size: 1.5rem;
    }
}
</style>

<script>
// Initialize Order Status Chart
document.addEventListener('DOMContentLoaded', function() {
    const chartCanvas = document.getElementById('orderStatusChart');
    if (!chartCanvas) return;

    // Check if Chart.js is available
    if (typeof Chart === 'undefined') {
        console.log('Chart.js not loaded, skipping chart initialization');
        return;
    }

    const ctx = chartCanvas.getContext('2d');
    const darkMode = document.documentElement.getAttribute('data-theme') === 'dark';
    
    const textColor = darkMode ? '#B0BEC5' : '#6B7280';
    const gridColor = darkMode ? '#37474F' : '#E5E7EB';

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Draft', 'Released', 'In Progress', 'Completed'],
            datasets: [{
                label: 'Work Orders',
                data: [@Model.DraftCount, @Model.ReleasedCount, @Model.InProgressCount, @Model.CompletedCount],
                fill: true,
                tension: 0.4,
                backgroundColor: darkMode ? 'rgba(59,130,246,0.16)' : 'rgba(59,130,246,0.12)',
                borderColor: 'rgba(59,130,246,0.95)',
                borderWidth: 2,
                pointRadius: 5,
                pointBackgroundColor: 'rgba(59,130,246,0.95)'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        color: textColor,
                        stepSize: 1
                    },
                    grid: {
                        color: gridColor,
                        drawBorder: false
                    }
                },
                x: {
                    ticks: {
                        color: textColor
                    },
                    grid: {
                        display: false,
                        drawBorder: false
                    }
                }
            }
        }
    });
});
</script>
