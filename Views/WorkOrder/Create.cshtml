@model SnackFlowMES.ViewModels.WorkOrderFormViewModel
@{
    ViewData["Title"] = "Create Work Order";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <p>@TempData["Success"]</p>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--error">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>@TempData["Error"]</p>
    </div>
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Create Work Order</h1>
        <p class="dash-page-subtitle">Create a new production work order</p>
    </div>
    <a asp-action="Index" class="dash-btn dash-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to List
    </a>
</div>

<div class="dash-card">
    <form asp-action="Create" asp-controller="WorkOrder" method="post" class="dash-form" id="workOrderForm" novalidate>
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="dash-alert dash-alert--error" style="margin-bottom:24px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div>
                    <strong>Please correct the following errors:</strong>
                    <ul style="margin:8px 0 0 16px;padding:0;">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- Section divider -->
        <div class="wo-section-label">Materials</div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ItemId" class="dash-label dash-label--required"></label>
                <select asp-for="ItemId" asp-items="ViewBag.Items" class="dash-select" required>
                    <option value="">-- Select Finished Good --</option>
                </select>
                <span asp-validation-for="ItemId" class="dash-error"></span>
            </div>
            <div class="dash-form-group">
                <label asp-for="BomId" class="dash-label dash-label--required"></label>
                <select asp-for="BomId" asp-items="ViewBag.Boms" class="dash-select" required>
                    <option value="">-- Select BOM --</option>
                </select>
                <span asp-validation-for="BomId" class="dash-error"></span>
            </div>
        </div>

        <!-- Section divider -->
        <div class="wo-section-label">Quantity</div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="PlannedQty" class="dash-label dash-label--required"></label>
                <input asp-for="PlannedQty" class="dash-input" type="number" step="0.01" min="0.01" placeholder="0.00" required />
                <span asp-validation-for="PlannedQty" class="dash-error"></span>
                <small class="dash-hint">Enter the quantity to produce</small>
            </div>
            <div class="dash-form-group">
                <label asp-for="UnitOfMeasure" class="dash-label dash-label--required"></label>
                <select asp-for="UnitOfMeasure" class="dash-select" required>
                    <option value="">-- Select Unit --</option>
                    <option value="kg">kg</option>
                    <option value="g">g</option>
                    <option value="L">L</option>
                    <option value="pcs">pcs</option>
                    <option value="bag">bag</option>
                    <option value="box">box</option>
                    <option value="pack">pack</option>
                </select>
                <span asp-validation-for="UnitOfMeasure" class="dash-error"></span>
            </div>
        </div>

        <!-- Section divider -->
        <div class="wo-section-label">Production Details</div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="Status" class="dash-label dash-label--required"></label>
                <select asp-for="Status" asp-items="ViewBag.Statuses" class="dash-select" required></select>
                <span asp-validation-for="Status" class="dash-error"></span>
                <small class="dash-hint">Default: Draft (can be changed later)</small>
            </div>
            <div class="dash-form-group">
                <label asp-for="ProductionLine" class="dash-label"></label>
                <input asp-for="ProductionLine" class="dash-input" placeholder="e.g., Line 1, Line A" />
                <span asp-validation-for="ProductionLine" class="dash-error"></span>
                <small class="dash-hint">Optional: specific production line</small>
            </div>
        </div>

        <!-- Section divider -->
        <div class="wo-section-label">Schedule</div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ScheduledStart" class="dash-label dash-label--required"></label>
                <input asp-for="ScheduledStart" class="dash-input" type="datetime-local" required />
                <span asp-validation-for="ScheduledStart" class="dash-error"></span>
            </div>
            <div class="dash-form-group">
                <label asp-for="ScheduledEnd" class="dash-label dash-label--required"></label>
                <input asp-for="ScheduledEnd" class="dash-input" type="datetime-local" required />
                <span asp-validation-for="ScheduledEnd" class="dash-error"></span>
            </div>
        </div>

        <!-- Section divider -->
        <div class="wo-section-label">Additional Information</div>

        <div class="dash-form-group">
            <label asp-for="Notes" class="dash-label"></label>
            <textarea asp-for="Notes" class="dash-textarea" rows="4" placeholder="Add any special instructions or notes..."></textarea>
            <span asp-validation-for="Notes" class="dash-error"></span>
            <small class="dash-hint">Optional: Additional instructions for production</small>
        </div>

        <div class="dash-form-actions">
            <button type="submit" class="dash-btn dash-btn--primary" id="submitBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Create Work Order
            </button>
            <a asp-action="Index" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

<style>
.wo-section-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-secondary);
    padding: 0 0 12px 0;
    margin: 24px 0 4px 0;
    border-bottom: 1px solid var(--border-color);
}

.wo-section-label:first-of-type {
    margin-top: 0;
}

.dash-form {
    padding: 28px;
}

.dash-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 0;
}

.dash-form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 20px;
}

.dash-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
}

.dash-label--required::after {
    content: ' *';
    color: #EF4444;
}

.dash-input,
.dash-select,
.dash-textarea {
    padding: 10px 14px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 0.9375rem;
    color: var(--text-primary);
    background: var(--bg-primary);
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
}

.dash-input:focus,
.dash-select:focus,
.dash-textarea:focus {
    outline: none;
    border-color: #3B82F6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.dash-textarea {
    resize: vertical;
    min-height: 100px;
}

.dash-hint {
    font-size: 0.8125rem;
    color: var(--text-secondary);
}

.dash-error {
    font-size: 0.8125rem;
    color: #EF4444;
    font-weight: 500;
}

.dash-form-actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border-color);
}

@@media (max-width: 768px) {
    .dash-form {
        padding: 20px 16px;
    }

    .dash-form-row {
        grid-template-columns: 1fr;
    }
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const bomData = @Html.Raw(ViewBag.BomData ?? "[]");

        document.addEventListener('DOMContentLoaded', function () {
            const itemSelect = document.querySelector('[name="ItemId"]');
            const bomSelect  = document.querySelector('[name="BomId"]');
            const form       = document.getElementById('workOrderForm');
            const submitBtn  = document.getElementById('submitBtn');

            let allBomOptions = [];
            if (bomData && bomData.length > 0) {
                allBomOptions = bomData.map(b => ({ value: b.BomId, text: b.BomName, itemId: b.ItemId }));
            }

            if (itemSelect && bomSelect) {
                itemSelect.addEventListener('change', function () {
                    const selectedItemId = parseInt(this.value);
                    bomSelect.value = '';
                    while (bomSelect.options.length > 1) bomSelect.remove(1);

                    if (selectedItemId) {
                        const matching = allBomOptions.filter(b => b.itemId === selectedItemId);
                        if (matching.length > 0) {
                            matching.forEach(b => bomSelect.add(new Option(b.text, b.value)));
                            bomSelect.disabled = false;
                        } else {
                            const opt = new Option('No BOMs available for this item', '');
                            opt.disabled = true;
                            bomSelect.add(opt);
                            bomSelect.disabled = true;
                        }
                    } else {
                        bomSelect.disabled = true;
                    }
                });

                if (!itemSelect.value) bomSelect.disabled = true;
            }

            if (form && submitBtn) {
                form.addEventListener('submit', function (e) {
                    const fields = {
                        'ItemId':         'Please select a Finished Good',
                        'BomId':          'Please select a Bill of Materials',
                        'UnitOfMeasure':  'Please select a Unit of Measure',
                        'ScheduledStart': 'Please select a Scheduled Start date',
                        'ScheduledEnd':   'Please select a Scheduled End date',
                    };

                    const errors = [];
                    for (const [name, msg] of Object.entries(fields)) {
                        const el = document.querySelector(`[name="${name}"]`);
                        if (el && !el.value) errors.push(msg);
                    }

                    const qty = document.querySelector('[name="PlannedQty"]');
                    if (!qty.value || parseFloat(qty.value) <= 0) errors.push('Planned Quantity must be greater than 0');

                    const start = document.querySelector('[name="ScheduledStart"]');
                    const end   = document.querySelector('[name="ScheduledEnd"]');
                    if (start.value && end.value && new Date(end.value) <= new Date(start.value))
                        errors.push('Scheduled End must be after Scheduled Start');

                    if (errors.length > 0) {
                        e.preventDefault();
                        alert('Please fix the following errors:\n\n' + errors.join('\n'));
                    } else {
                        submitBtn.disabled = true;
                        submitBtn.style.opacity = '0.6';
                    }
                });
            }
        });
    </script>
}
