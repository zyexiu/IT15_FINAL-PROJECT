@model SnackFlowMES.ViewModels.WorkOrderFormViewModel
@{
    ViewData["Title"] = "Edit Work Order";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Edit Work Order</h1>
        <p class="dash-page-subtitle">Update work order details</p>
    </div>
    <a asp-action="Index" class="dash-btn dash-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to List
    </a>
</div>

<div class="dash-card">
    <form asp-action="Edit" method="post" class="dash-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="WorkOrderId" />
        <div asp-validation-summary="ModelOnly" class="dash-validation-summary"></div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ItemId" class="dash-label"></label>
                <select asp-for="ItemId" asp-items="ViewBag.Items" class="dash-select">
                    <option value="">-- Select Finished Good --</option>
                </select>
                <span asp-validation-for="ItemId" class="dash-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="BomId" class="dash-label"></label>
                <select asp-for="BomId" asp-items="ViewBag.Boms" class="dash-select">
                    <option value="">-- Select BOM --</option>
                </select>
                <span asp-validation-for="BomId" class="dash-error"></span>
            </div>
        </div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="PlannedQty" class="dash-label"></label>
                <input asp-for="PlannedQty" class="dash-input" type="number" step="0.01" />
                <span asp-validation-for="PlannedQty" class="dash-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="UnitOfMeasure" class="dash-label"></label>
                <select asp-for="UnitOfMeasure" class="dash-select">
                    <option value="kg">kg</option>
                    <option value="g">g</option>
                    <option value="L">L</option>
                    <option value="pcs">pcs</option>
                    <option value="bag">bag</option>
                    <option value="box">box</option>
                    <option value="pack">pack</option>
                </select>
                <span asp-validation-for="UnitOfMeasure" class="dash-error"></span>
            </div>
        </div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="Status" class="dash-label"></label>
                <select asp-for="Status" asp-items="ViewBag.Statuses" class="dash-select"></select>
                <span asp-validation-for="Status" class="dash-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="ProductionLine" class="dash-label"></label>
                <input asp-for="ProductionLine" class="dash-input" placeholder="e.g., Line 1, Line 2" />
                <span asp-validation-for="ProductionLine" class="dash-error"></span>
            </div>
        </div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ScheduledStart" class="dash-label"></label>
                <input asp-for="ScheduledStart" class="dash-input" type="datetime-local" />
                <span asp-validation-for="ScheduledStart" class="dash-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="ScheduledEnd" class="dash-label"></label>
                <input asp-for="ScheduledEnd" class="dash-input" type="datetime-local" />
                <span asp-validation-for="ScheduledEnd" class="dash-error"></span>
            </div>
        </div>

        <div class="dash-form-group">
            <label asp-for="Notes" class="dash-label"></label>
            <textarea asp-for="Notes" class="dash-textarea" rows="3" placeholder="Optional notes..."></textarea>
            <span asp-validation-for="Notes" class="dash-error"></span>
        </div>

        <div class="dash-form-actions">
            <button type="submit" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Save Changes
            </button>
            <a asp-action="Index" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
