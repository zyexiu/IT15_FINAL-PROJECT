@model SnackFlowMES.Models.WorkOrder
@{
    ViewData["Title"] = Model.WoNumber;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">@Model.WoNumber</h1>
        <p class="dash-page-subtitle">@(Model.Item?.ItemName ?? "Work Order")</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
        {
            <a asp-action="Edit" asp-route-id="@Model.WorkOrderId" class="dash-btn dash-btn--secondary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit
            </a>
        }
        <a asp-action="Index" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to List
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

<div class="dash-grid-2">
    <!-- Left column: Details -->
    <div class="dash-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Work Order Information
            </h2>
            @{
                var statusColor = Model.Status switch
                {
                    "Draft" => "#6B7280",
                    "Released" => "#3B82F6",
                    "InProgress" => "#F59E0B",
                    "Completed" => "#10B981",
                    "Cancelled" => "#EF4444",
                    _ => "#6B7280"
                };
            }
            <span style="display:inline-block;padding:4px 12px;border-radius:12px;font-size:0.75rem;font-weight:600;color:white;background:@statusColor;">
                @Model.Status
            </span>
        </div>
        <div class="dash-detail-grid">
            <div class="dash-detail-item">
                <span class="dash-detail-label">WO Number</span>
                <span class="dash-detail-value" style="font-family:monospace;font-weight:600;color:#3B82F6;">@Model.WoNumber</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Finished Good</span>
                <span class="dash-detail-value" style="font-weight:600;">@(Model.Item?.ItemName ?? "—")</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">BOM</span>
                <span class="dash-detail-value">
                    @if (Model.Bom != null)
                    {
                        <span>@Model.Bom.Item?.ItemName</span>
                    }
                    else
                    {
                        <span style="color:#9CA3AF;">—</span>
                    }
                </span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Production Line</span>
                <span class="dash-detail-value">
                    @if (!string.IsNullOrEmpty(Model.ProductionLine))
                    {
                        <span style="display:inline-block;padding:3px 10px;border-radius:10px;font-size:0.8125rem;font-weight:500;background:rgba(59,130,246,0.1);color:#3B82F6;">
                            @Model.ProductionLine
                        </span>
                    }
                    else
                    {
                        <span style="color:#9CA3AF;">Not assigned</span>
                    }
                </span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Planned Quantity</span>
                <span class="dash-detail-value" style="font-weight:600;color:#3B82F6;">@Model.PlannedQty.ToString("N2") @Model.UnitOfMeasure</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Actual Quantity</span>
                <span class="dash-detail-value" style="font-weight:600;color:@(Model.ActualQty >= Model.PlannedQty ? "#10B981" : "#F59E0B");">@Model.ActualQty.ToString("N2") @Model.UnitOfMeasure</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Progress</span>
                <span class="dash-detail-value">
                    @{
                        var progress = Model.PlannedQty > 0 ? (Model.ActualQty / Model.PlannedQty * 100) : 0;
                        var progressColor = progress >= 100 ? "#10B981" : progress >= 50 ? "#F59E0B" : "#6B7280";
                    }
                    <div style="display:flex;align-items:center;gap:8px;">
                        <div style="flex:1;height:8px;background:#E5E7EB;border-radius:4px;overflow:hidden;">
                            <div style="height:100%;background:@progressColor;width:@Math.Min(progress, 100)%;transition:width 0.3s;"></div>
                        </div>
                        <span style="font-weight:600;color:@progressColor;min-width:45px;">@progress.ToString("N0")%</span>
                    </div>
                </span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Scheduled Start</span>
                <span class="dash-detail-value">@Model.ScheduledStart.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Scheduled End</span>
                <span class="dash-detail-value">@Model.ScheduledEnd.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
            @if (Model.ActualStart.HasValue)
            {
                <div class="dash-detail-item">
                    <span class="dash-detail-label">Actual Start</span>
                    <span class="dash-detail-value" style="color:#10B981;font-weight:500;">@Model.ActualStart.Value.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
            }
            @if (Model.ActualEnd.HasValue)
            {
                <div class="dash-detail-item">
                    <span class="dash-detail-label">Actual End</span>
                    <span class="dash-detail-value" style="color:#10B981;font-weight:500;">@Model.ActualEnd.Value.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
            }
            <div class="dash-detail-item">
                <span class="dash-detail-label">Created By</span>
                <span class="dash-detail-value">@(Model.CreatedBy?.FullName ?? "—")</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Created At</span>
                <span class="dash-detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div style="margin-top:20px;padding:20px;background:rgba(59,130,246,0.03);border-radius:8px;border-left:3px solid #3B82F6;">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#3B82F6;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                    <span class="dash-detail-label" style="margin:0;">Notes</span>
                </div>
                <p style="margin:0;color:#6B7A8D;line-height:1.6;font-size:0.9375rem;">@Model.Notes</p>
            </div>
        }
    </div>

    <!-- Right column: Status actions -->
    <div>
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><activity width="18" height="18"/><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    Status Actions
                </h2>
            </div>
            <div style="padding:20px;display:flex;flex-direction:column;gap:12px;">
                @if (Model.Status == "Draft")
                {
                    <form asp-action="UpdateStatus" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.WorkOrderId" />
                        <input type="hidden" name="status" value="Released" />
                        <button type="submit" class="dash-btn dash-btn--primary dash-btn--full">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            Release Work Order
                        </button>
                    </form>
                }
                @if (Model.Status == "Released")
                {
                    <form asp-action="UpdateStatus" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.WorkOrderId" />
                        <input type="hidden" name="status" value="InProgress" />
                        <button type="submit" class="dash-btn dash-btn--primary dash-btn--full">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            Start Production
                        </button>
                    </form>
                }
                @if (Model.Status == "InProgress")
                {
                    <form asp-action="UpdateStatus" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.WorkOrderId" />
                        <input type="hidden" name="status" value="Completed" />
                        <button type="submit" class="dash-btn dash-btn--success dash-btn--full">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            Complete Work Order
                        </button>
                    </form>
                }
                @if (Model.Status != "Completed" && Model.Status != "Cancelled")
                {
                    <form asp-action="UpdateStatus" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.WorkOrderId" />
                        <input type="hidden" name="status" value="Cancelled" />
                        <button type="submit" class="dash-btn dash-btn--danger dash-btn--full" onclick="return confirm('Are you sure you want to cancel this work order?');">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                            Cancel Work Order
                        </button>
                    </form>
                }
                
                @if (Model.Status == "Draft" || Model.Status == "Released" || Model.Status == "InProgress")
                {
                    <div style="margin-top:8px;padding:12px;background:rgba(59,130,246,0.05);border-radius:8px;border-left:3px solid #3B82F6;">
                        <p style="margin:0;font-size:0.8125rem;color:#6B7280;line-height:1.5;">
                            <strong style="color:#3B82F6;">Status Flow:</strong><br/>
                            Draft → Released → In Progress → Completed
                        </p>
                    </div>
                }
            </div>
        </div>

        @if (Model.Materials != null && Model.Materials.Any())
        {
            <div class="dash-card" style="margin-top:24px;">
                <div class="dash-card-header">
                    <h2 class="dash-card-title">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                        Materials
                    </h2>
                    <span style="font-size:0.75rem;color:#6B7280;font-weight:500;">@Model.Materials.Count items</span>
                </div>
                <div class="dash-list">
                    @foreach (var mat in Model.Materials)
                    {
                        <div class="dash-list-item">
                            <div style="flex:1;">
                                <div class="dash-list-item-title">@(mat.Item?.ItemName ?? "—")</div>
                                <div class="dash-list-item-subtitle">@(mat.Item?.ItemCode ?? "—")</div>
                            </div>
                            <div style="text-align:right;">
                                <div class="dash-list-item-value" style="font-weight:600;color:#3B82F6;">
                                    @mat.PlannedQty.ToString("N2") @mat.UnitOfMeasure
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* Downtime Reports Section *@
        @{
            var downtimeReports = ViewBag.DowntimeReports as List<SnackFlowMES.Models.DowntimeReport> ?? new List<SnackFlowMES.Models.DowntimeReport>();
            var totalDowntime = ViewBag.TotalDowntime as int? ?? 0;
        }
        @if (downtimeReports.Any() || (Model.Status == "Released" || Model.Status == "InProgress"))
        {
            <div class="dash-card" style="margin-top:24px;">
                <div class="dash-card-header">
                    <h2 class="dash-card-title">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        Downtime Reports
                    </h2>
                    @if (totalDowntime > 0)
                    {
                        <span style="font-size:0.875rem;color:#EF4444;font-weight:600;">
                            Total: @(totalDowntime >= 60 ? $"{(totalDowntime / 60.0):F1}h" : $"{totalDowntime}m")
                        </span>
                    }
                </div>
                
                @if (!downtimeReports.Any())
                {
                    <div style="padding:40px 20px;text-align:center;color:var(--text-secondary);">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3;margin-bottom:12px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        <p style="margin:0;font-size:0.875rem;">No downtime reported for this work order</p>
                        @if ((Model.Status == "Released" || Model.Status == "InProgress") && User.IsInRole("Operator"))
                        {
                            <a href="/Downtime/Create?workOrderId=@Model.WorkOrderId" style="display:inline-block;margin-top:12px;color:#3B82F6;text-decoration:none;font-weight:500;font-size:0.875rem;">
                                Report Downtime →
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="dash-list">
                        @foreach (var downtime in downtimeReports)
                        {
                            var downtimeStatusColor = downtime.Status switch
                            {
                                "Open" => "#F59E0B",
                                "Resolved" => "#10B981",
                                "Escalated" => "#EF4444",
                                _ => "#6B7280"
                            };

                            var reasonColor = downtime.Reason switch
                            {
                                "Machine Breakdown" => "#EF4444",
                                "Material Shortage" => "#F59E0B",
                                "Power Outage" => "#EF4444",
                                "Maintenance" => "#3B82F6",
                                "Changeover" => "#10B981",
                                _ => "#6B7280"
                            };

                            var durationDisplay = downtime.DurationMinutes >= 60 
                                ? $"{(downtime.DurationMinutes / 60.0):F1}h" 
                                : $"{downtime.DurationMinutes}m";

                            <div class="dash-list-item" style="align-items:flex-start;">
                                <div style="flex:1;">
                                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                        <span style="display:inline-block;padding:3px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;color:white;background:@reasonColor;">
                                            @downtime.Reason
                                        </span>
                                        <span style="display:inline-block;padding:3px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;color:white;background:@downtimeStatusColor;">
                                            @downtime.Status
                                        </span>
                                        <span style="font-size:0.75rem;color:var(--text-secondary);">
                                            @downtime.StartTime.ToString("MMM dd, HH:mm")
                                        </span>
                                    </div>
                                    <div class="dash-list-item-title" style="margin-bottom:4px;">@downtime.ProductionLine</div>
                                    <div class="dash-list-item-subtitle">@downtime.Description</div>
                                    <div style="margin-top:8px;font-size:0.75rem;color:var(--text-secondary);">
                                        Reported by @downtime.ReportedBy?.FullName
                                        @if (downtime.ResolvedBy != null)
                                        {
                                            <span> • Resolved by @downtime.ResolvedBy.FullName</span>
                                        }
                                    </div>
                                </div>
                                <div style="text-align:right;">
                                    <div style="font-weight:600;font-size:1.125rem;color:@(downtime.DurationMinutes > 60 ? "#EF4444" : "#6B7280");margin-bottom:4px;">
                                        @durationDisplay
                                    </div>
                                    <a href="/Downtime/Details/@downtime.DowntimeId" style="font-size:0.75rem;color:#3B82F6;text-decoration:none;font-weight:500;">
                                        View Details →
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if ((User.IsInRole("Admin") || User.IsInRole("Planner")) && (Model.Status == "Draft" || Model.Status == "Cancelled"))
        {
            <div class="dash-card" style="margin-top:24px;">
                <div class="dash-card-header">
                    <h2 class="dash-card-title" style="color:#EF4444;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Danger Zone
                    </h2>
                </div>
                <div style="padding: 20px;">
                    <p style="color: #6B7A8D; font-size: 0.875rem; margin-bottom: 16px;line-height:1.6;">
                        Permanently delete this work order. This action cannot be undone and will remove all associated data.
                    </p>
                    <form asp-action="Delete" asp-route-id="@Model.WorkOrderId" method="post" style="margin:0;" onsubmit="return confirm('Are you sure you want to permanently delete work order @Model.WoNumber? This action cannot be undone.');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dash-btn dash-btn--danger dash-btn--full">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                            Delete Work Order
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>


<style>
.dash-btn--warning {
    background: #F59E0B;
    color: white;
    border: none;
}

.dash-btn--warning:hover {
    background: #D97706;
}
</style>
