@model IEnumerable<SnackFlowMES.Models.Item>
@{
    ViewData["Title"] = "Inventory";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var typeFilter = ViewBag.TypeFilter as string;
    var q = ViewContext.HttpContext.Request.Query["q"].ToString();
    var lowstock = ViewContext.HttpContext.Request.Query["lowstock"].ToString();
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Inventory Management</h1>
        <p class="dash-page-subtitle">Manage items and stock levels</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        @if (ViewBag.ShowArchived)
        {
            <a asp-action="Index" asp-route-archived="false" class="dash-btn dash-btn--secondary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Show Active Items
            </a>
        }
        else
        {
            <a asp-action="Index" asp-route-archived="true" class="dash-btn dash-btn--secondary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
                Show Archived (@ViewBag.ArchivedCount)
            </a>
        }
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add New Item
            </a>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const searchForm = document.querySelector('.dash-search-form');
        if (!searchForm) {
            return;
        }

        const input = searchForm.querySelector('input[name="q"]');
        const clearButton = searchForm.querySelector('.dash-search-clear');

        const updateClearVisibility = function () {
            if (!input || !clearButton) {
                return;
            }

            clearButton.classList.toggle('is-hidden', !input.value.trim());
        };

        if (input && clearButton) {
            input.addEventListener('input', updateClearVisibility);
            updateClearVisibility();

            clearButton.addEventListener('click', function () {
                input.value = '';
                updateClearVisibility();
                searchForm.submit();
            });
        }
    });
</script>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--danger">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        @TempData["Error"]
    </div>
}

@if (ViewBag.ShowArchived)
{
    <div class="dash-alert dash-alert--info">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
        Viewing archived items. These items can be permanently deleted or restored.
    </div>
}

<!-- Type filter tabs -->
<div class="dash-tabs">
    <a href="@Url.Action("Index", new { q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived })" class="dash-tab @(string.IsNullOrEmpty(typeFilter) ? "dash-tab--active" : "")">
        All Items (@ViewBag.TotalCount)
    </a>
    <a href="@Url.Action("Index", new { type = "RawMaterial", q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived })" class="dash-tab @(typeFilter == "RawMaterial" ? "dash-tab--active" : "")">
        Raw Materials (@ViewBag.RawMaterialCount)
    </a>
    <a href="@Url.Action("Index", new { type = "Packaging", q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived })" class="dash-tab @(typeFilter == "Packaging" ? "dash-tab--active" : "")">
        Packaging (@ViewBag.PackagingCount)
    </a>
    <a href="@Url.Action("Index", new { type = "FinishedGood", q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived })" class="dash-tab @(typeFilter == "FinishedGood" ? "dash-tab--active" : "")">
        Finished Goods (@ViewBag.FinishedGoodCount)
    </a>
    <a href="@Url.Action("Index", new { type = "SemiFinished", q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived })" class="dash-tab @(typeFilter == "SemiFinished" ? "dash-tab--active" : "")">
        Semi-Finished (@ViewBag.SemiFinishedCount)
    </a>
</div>

<!-- Tabs row controls: search + filter -->
<div class="dash-tabs-row">
    <form method="get" action="@Url.Action("Index")" class="dash-search-form">
        <input type="hidden" name="type" value="@(typeFilter ?? "")" />
        <input type="hidden" name="lowstock" value="@(string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock)" />
        <input type="hidden" name="archived" value="@ViewBag.Archived" />
        <div class="dash-search-input-wrap">
            <input type="text" name="q" placeholder="Search items" value="@q" aria-label="Search items" />
            <button type="button" class="dash-search-clear" aria-label="Clear search" onclick="const input=this.parentElement.querySelector('input[name=q]'); input.value=''; this.form.submit();">×</button>
        </div>
        <button type="submit" class="dash-btn dash-btn--secondary dash-btn--sm">Search</button>
    </form>

    <form method="get" action="@Url.Action("Index")" class="dash-filter-form">
        <input type="hidden" name="type" value="@(typeFilter ?? "")" />
        <input type="hidden" name="q" value="@q" />
        <input type="hidden" name="archived" value="@ViewBag.Archived" />
        <label class="dash-filter-label">FILTER</label>
        <select name="lowstock" class="dash-filter-select" onchange="this.form.submit()">
            @if (lowstock == "all" || string.IsNullOrWhiteSpace(lowstock)) {
                <option value="all" selected>All Stock</option>
            } else {
                <option value="all">All Stock</option>
            }
            @if (lowstock == "normal") {
                <option value="normal" selected>Normal Stock</option>
            } else {
                <option value="normal">Normal Stock</option>
            }
            @if (lowstock == "low") {
                <option value="low" selected>Low Stock</option>
            } else {
                <option value="low">Low Stock</option>
            }
        </select>
    </form>
</div>

@if (!Model.Any())
{
    <div class="dash-empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        <h3>No items found</h3>
        <p>@(string.IsNullOrEmpty(typeFilter) ? "Add your first inventory item to get started." : $"No items of type '{typeFilter}'.")</p>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="dash-btn dash-btn--primary" style="margin-top:16px;">Add New Item</a>
        }
    </div>
}
else
{
    <div class="dash-inventory-grid">
        @foreach (var item in Model)
        {
            var balance = item.InventoryBalance;
            var qtyOnHand = balance?.QtyOnHand ?? 0;
            var isLowStock = item.ReorderPoint > 0 && qtyOnHand <= item.ReorderPoint;

            <div class="dash-inventory-card @(isLowStock ? "dash-inventory-card--low-stock" : "")">
                @if (isLowStock)
                {
                    <div class="dash-inventory-alert">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Low Stock
                    </div>
                }

                <div class="dash-inventory-card-header">
                    <div class="dash-inventory-icon dash-inventory-icon--@item.ItemType.ToLower()">
                        @switch (item.ItemType)
                        {
                            case "RawMaterial":
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                break;
                            case "Packaging":
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                                break;
                            case "FinishedGood":
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                break;
                            default:
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
                                break;
                        }
                    </div>
                    <div style="display:flex;gap:4px;">
                        @if (item.IsArchived)
                        {
                            <span class="dash-badge dash-badge--warning">Archived</span>
                        }
                        else
                        {
                            <span class="dash-badge dash-badge--secondary">@item.ItemType</span>
                        }
                    </div>
                </div>

                <div class="dash-inventory-card-body">
                    <h3 class="dash-inventory-card-title">@item.ItemName</h3>
                    <p class="dash-inventory-card-code">@item.ItemCode</p>
                    @if (!string.IsNullOrEmpty(item.Category))
                    {
                        <p class="dash-inventory-card-category">@item.Category</p>
                    }
                </div>

                <div class="dash-inventory-card-stock">
                    <div class="dash-inventory-stock-label">Stock on Hand</div>
                    <div class="dash-inventory-stock-value">
                        @qtyOnHand.ToString("N2") <span class="dash-inventory-stock-unit">@item.UnitOfMeasure</span>
                    </div>
                    @if (item.ReorderPoint > 0)
                    {
                        <div class="dash-inventory-stock-reorder">
                            Reorder at: @item.ReorderPoint.ToString("N2") @item.UnitOfMeasure
                        </div>
                    }
                </div>

                <div class="dash-inventory-card-footer">
                    <a asp-action="Details" asp-route-id="@item.ItemId" class="dash-btn dash-btn--secondary dash-btn--sm dash-btn--full">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        View Details
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="dash-pagination">
            <div class="dash-pagination-info">
                Showing @((ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1) to @(Math.Min(ViewBag.CurrentPage * ViewBag.PageSize, ViewBag.TotalItems)) of @ViewBag.TotalItems items
            </div>
            <div class="dash-pagination-controls">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="@Url.Action("Index", new { type = typeFilter, q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived, page = ViewBag.CurrentPage - 1 })" class="dash-pagination-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        Previous
                    </a>
                }
                else
                {
                    <span class="dash-pagination-btn dash-pagination-btn--disabled">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        Previous
                    </span>
                }

                <div class="dash-pagination-pages">
                    @{
                        var startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                        var endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);

                        if (startPage > 1)
                        {
                            <a href="@Url.Action("Index", new { type = typeFilter, q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived, page = 1 })" class="dash-pagination-page">1</a>
                            if (startPage > 2)
                            {
                                <span class="dash-pagination-ellipsis">...</span>
                            }
                        }

                        for (var i = startPage; i <= endPage; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <span class="dash-pagination-page dash-pagination-page--active">@i</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", new { type = typeFilter, q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived, page = i })" class="dash-pagination-page">@i</a>
                            }
                        }

                        if (endPage < ViewBag.TotalPages)
                        {
                            if (endPage < ViewBag.TotalPages - 1)
                            {
                                <span class="dash-pagination-ellipsis">...</span>
                            }
                            <a href="@Url.Action("Index", new { type = typeFilter, q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived, page = ViewBag.TotalPages })" class="dash-pagination-page">@ViewBag.TotalPages</a>
                        }
                    }
                </div>

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="@Url.Action("Index", new { type = typeFilter, q, lowstock = string.IsNullOrWhiteSpace(lowstock) ? "all" : lowstock, archived = ViewBag.Archived, page = ViewBag.CurrentPage + 1 })" class="dash-pagination-btn">
                        Next
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                }
                else
                {
                    <span class="dash-pagination-btn dash-pagination-btn--disabled">
                        Next
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </span>
                }
            </div>
        </div>
    }
}
