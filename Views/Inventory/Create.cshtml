@model SnackFlowMES.ViewModels.ItemFormViewModel
@{
    ViewData["Title"] = "Add New Item";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Add New Item</h1>
        <p class="dash-page-subtitle">Create a new inventory item</p>
    </div>
    <a asp-action="Index" class="dash-btn dash-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to List
    </a>
</div>

<div class="dash-card">
    <form asp-action="Create" method="post" class="dash-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="dash-validation-summary"></div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ItemCode" class="dash-label"></label>
                <input asp-for="ItemCode" class="dash-input" placeholder="e.g., RM-001, PK-001, FG-001" />
                <span asp-validation-for="ItemCode" class="dash-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="ItemName" class="dash-label"></label>
                <input asp-for="ItemName" class="dash-input" placeholder="e.g., Potato Flour, Plastic Bag, Sea Salt Chips" />
                <span asp-validation-for="ItemName" class="dash-error"></span>
            </div>
        </div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ItemType" class="dash-label"></label>
                <select asp-for="ItemType" asp-items="ViewBag.ItemTypes" class="dash-select"></select>
                <span asp-validation-for="ItemType" class="dash-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="Category" class="dash-label"></label>
                <input asp-for="Category" class="dash-input" placeholder="e.g., Flour, Seasoning, Snacks" />
                <span asp-validation-for="Category" class="dash-error"></span>
            </div>
        </div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="UnitOfMeasure" class="dash-label"></label>
                <select asp-for="UnitOfMeasure" asp-items="ViewBag.UnitOfMeasures" class="dash-select"></select>
                <span asp-validation-for="UnitOfMeasure" class="dash-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="UnitCost" class="dash-label"></label>
                <input asp-for="UnitCost" class="dash-input" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="UnitCost" class="dash-error"></span>
            </div>
        </div>

        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ReorderPoint" class="dash-label"></label>
                <input asp-for="ReorderPoint" class="dash-input" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="ReorderPoint" class="dash-error"></span>
                <small class="dash-hint">Minimum stock level before reorder alert</small>
            </div>
        </div>

        <div class="dash-form-group">
            <label asp-for="Description" class="dash-label"></label>
            <textarea asp-for="Description" class="dash-textarea" rows="3" placeholder="Optional description..."></textarea>
            <span asp-validation-for="Description" class="dash-error"></span>
        </div>

        <div class="dash-form-actions">
            <button type="submit" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Create Item
            </button>
            <a asp-action="Index" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
