@model SnackFlowMES.Models.Item
@{
    ViewData["Title"] = Model.ItemName;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var balance = Model.InventoryBalance;
    var qtyOnHand = balance?.QtyOnHand ?? 0;
    var isLowStock = Model.ReorderPoint > 0 && qtyOnHand <= Model.ReorderPoint;
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">@Model.ItemName</h1>
        <p class="dash-page-subtitle">@Model.ItemCode</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        @if (User.IsInRole("Admin"))
        {
            @if (!Model.IsArchived)
            {
                <a asp-action="Edit" asp-route-id="@Model.ItemId" class="dash-btn dash-btn--secondary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit
                </a>
            }
        }
        @if (User.IsInRole("Admin"))
        {
            @if (Model.IsArchived)
            {
                <form asp-action="Unarchive" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ItemId" />
                    <button type="submit" class="dash-btn dash-btn--success" onclick="return confirm('Restore this item from archive?');">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                        Restore
                    </button>
                </form>
                <form asp-action="Delete" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ItemId" />
                    <button type="submit" class="dash-btn dash-btn--danger" onclick="return confirm('⚠️ PERMANENT DELETE\n\nThis will permanently delete this item and all its history from the database.\n\nThis action CANNOT be undone!\n\nAre you absolutely sure?');">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                        Delete Permanently
                    </button>
                </form>
            }
            else
            {
                <form asp-action="Archive" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ItemId" />
                    <button type="submit" class="dash-btn dash-btn--warning" onclick="return confirm('Archive this item? It will be hidden from active inventory but can be restored later.');">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
                        Archive
                    </button>
                </form>
            }
        }
        <a asp-action="Index" asp-route-archived="@(Model.IsArchived ? "true" : "false")" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to List
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--danger">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        @TempData["Error"]
    </div>
}

@if (Model.IsArchived)
{
    <div class="dash-alert dash-alert--warning">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
        This item is archived. It cannot be edited or used in new transactions. You can restore it or permanently delete it.
    </div>
}

@if (isLowStock)
{
    <div class="dash-alert dash-alert--warning">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Low Stock Alert: Current stock (@qtyOnHand.ToString("N2") @Model.UnitOfMeasure) is below reorder point (@Model.ReorderPoint.ToString("N2") @Model.UnitOfMeasure)
    </div>
}

<div class="dash-grid-2">
    <!-- Left column: Item Details -->
    <div>
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    Item Information
                </h2>
                @{
                    var itemTypeColor = Model.ItemType switch
                    {
                        "FinishedGood" => "#10B981",
                        "RawMaterial" => "#3B82F6",
                        "Packaging" => "#F59E0B",
                        _ => "#6B7280"
                    };
                    var itemTypeLabel = Model.ItemType switch
                    {
                        "FinishedGood" => "Finished Good",
                        "RawMaterial" => "Raw Material",
                        "Packaging" => "Packaging",
                        _ => Model.ItemType
                    };
                }
                <span style="display:inline-block;padding:4px 12px;border-radius:12px;font-size:0.75rem;font-weight:600;color:white;background:@itemTypeColor;">
                    @itemTypeLabel
                </span>
            </div>
            <div class="inv-detail-grid">
                <div class="inv-detail-item">
                    <span class="inv-detail-label">Item Code</span>
                    <span class="inv-detail-value" style="font-family:monospace;font-weight:600;color:#3B82F6;">@Model.ItemCode</span>
                </div>
                <div class="inv-detail-item">
                    <span class="inv-detail-label">Item Name</span>
                    <span class="inv-detail-value" style="font-weight:600;">@Model.ItemName</span>
                </div>
                <div class="inv-detail-item">
                    <span class="inv-detail-label">Category</span>
                    <span class="inv-detail-value">
                        @if (!string.IsNullOrEmpty(Model.Category))
                        {
                            <span style="display:inline-block;padding:3px 10px;border-radius:10px;font-size:0.8125rem;font-weight:500;background:rgba(59,130,246,0.1);color:#3B82F6;">
                                @Model.Category
                            </span>
                        }
                        else
                        {
                            <span style="color:#9CA3AF;">—</span>
                        }
                    </span>
                </div>
                <div class="inv-detail-item">
                    <span class="inv-detail-label">Unit of Measure</span>
                    <span class="inv-detail-value">@Model.UnitOfMeasure</span>
                </div>
                <div class="inv-detail-item">
                    <span class="inv-detail-label">Unit Cost</span>
                    <span class="inv-detail-value" style="font-weight:600;color:#10B981;">$@Model.UnitCost.ToString("N2")</span>
                </div>
                <div class="inv-detail-item">
                    <span class="inv-detail-label">Reorder Point</span>
                    <span class="inv-detail-value">
                        @if (Model.ReorderPoint > 0)
                        {
                            <span style="font-weight:600;color:@(isLowStock ? "#EF4444" : "#6B7280");">
                                @Model.ReorderPoint.ToString("N2") @Model.UnitOfMeasure
                            </span>
                        }
                        else
                        {
                            <span style="color:#9CA3AF;">Not set</span>
                        }
                    </span>
                </div>
                <div class="inv-detail-item">
                    <span class="inv-detail-label">Status</span>
                    <span class="inv-detail-value">
                        @if (Model.IsArchived)
                        {
                            <span style="display:inline-block;padding:4px 10px;border-radius:12px;font-size:0.75rem;font-weight:600;color:#D97706;background:rgba(251,191,36,0.12);">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
                                Archived
                            </span>
                        }
                        else if (Model.IsActive)
                        {
                            <span style="display:inline-block;padding:4px 10px;border-radius:12px;font-size:0.75rem;font-weight:600;color:#059669;background:rgba(16,185,129,0.12);">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Active
                            </span>
                        }
                        else
                        {
                            <span style="display:inline-block;padding:4px 10px;border-radius:12px;font-size:0.75rem;font-weight:600;color:#6B7280;background:rgba(107,114,128,0.12);">
                                Inactive
                            </span>
                        }
                    </span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div style="margin:0 0 20px;padding:16px 20px;background:rgba(59,130,246,0.05);border-top:1px solid var(--border-color);border-left:3px solid #3B82F6;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#3B82F6;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                        <span class="inv-detail-label" style="margin:0;">Description</span>
                    </div>
                    <p style="margin:0;color:#6B7A8D;line-height:1.6;font-size:0.9375rem;">@Model.Description</p>
                </div>
            }

<style>
.inv-detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0;
    padding: 8px 0;
}

.inv-detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border-color);
}

.inv-detail-item:nth-last-child(-n+2) {
    border-bottom: none;
}

.inv-detail-label {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.6px;
}

.inv-detail-value {
    font-size: 0.9375rem;
    color: var(--text-primary);
    font-weight: 500;
    margin-top: 2px;
}
</style>
        </div>

        @if (User.IsInRole("Admin") && !Model.IsArchived)
        {
            <div class="dash-card" style="margin-top:16px;">
                <div class="dash-card-header">
                    <h2 class="dash-card-title">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Adjust Stock
                    </h2>
                </div>
                <div style="padding:20px;">
                    <form asp-action="UpdateQuantity" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.ItemId" />
                        
                        <div class="dash-form-group">
                            <label class="dash-form-label">Quantity</label>
                            <input type="number" name="quantity" class="dash-form-input" step="0.01" required placeholder="0.00" />
                        </div>

                        <div class="dash-form-group">
                            <label class="dash-form-label">Transaction Type</label>
                            <select name="transactionType" class="dash-form-input" required>
                                <option value="Add">Add to Stock</option>
                                <option value="Remove">Remove from Stock</option>
                                <option value="Set">Set Stock Level</option>
                            </select>
                        </div>

                        <button type="submit" class="dash-btn dash-btn--primary dash-btn--full">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Update Stock
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

    <!-- Right column: Stock Info & History -->
    <div>
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Current Stock</h2>
            </div>
            <div class="dash-stock-display">
                <div class="dash-stock-main">
                    <div class="dash-stock-value">@qtyOnHand.ToString("N2")</div>
                    <div class="dash-stock-unit">@Model.UnitOfMeasure</div>
                </div>
                @if (balance != null)
                {
                    <div class="dash-stock-details">
                        <div class="dash-stock-detail-item">
                            <span class="dash-stock-detail-label">On Hand</span>
                            <span class="dash-stock-detail-value">@balance.QtyOnHand.ToString("N2")</span>
                        </div>
                        <div class="dash-stock-detail-item">
                            <span class="dash-stock-detail-label">Reserved</span>
                            <span class="dash-stock-detail-value">@balance.QtyReserved.ToString("N2")</span>
                        </div>
                        <div class="dash-stock-detail-item">
                            <span class="dash-stock-detail-label">Available</span>
                            <span class="dash-stock-detail-value">@balance.QtyAvailable.ToString("N2")</span>
                        </div>
                        <div class="dash-stock-detail-item">
                            <span class="dash-stock-detail-label">Last Updated</span>
                            <span class="dash-stock-detail-value">@balance.LastUpdated.ToString("MMM dd, HH:mm")</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Recent Transactions -->
        @if (Model.InventoryLedgers != null && Model.InventoryLedgers.Any())
        {
            <div class="dash-card" style="margin-top:16px;">
                <div class="dash-card-header">
                    <h2 class="dash-card-title">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                        Recent Transactions
                    </h2>
                    <span style="font-size:0.75rem;color:#6B7280;font-weight:500;background:rgba(59,130,246,0.08);padding:3px 10px;border-radius:10px;">Last 10</span>
                </div>
                <div>
                    @foreach (var ledger in Model.InventoryLedgers.OrderByDescending(l => l.PostedAt).Take(10))
                    {
                        var isPositive = ledger.Qty >= 0;
                        var qtyColor   = isPositive ? "#10B981" : "#EF4444";
                        var bgColor    = isPositive ? "rgba(16,185,129,0.05)" : "rgba(239,68,68,0.05)";
                        var dotColor   = isPositive ? "#10B981" : "#EF4444";

                        <div style="display:flex;align-items:center;gap:16px;padding:14px 20px;border-bottom:1px solid var(--border-color);">
                            <!-- Type dot -->
                            <div style="width:36px;height:36px;border-radius:50%;background:@bgColor;border:2px solid @dotColor;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                @if (isPositive)
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="@dotColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="@dotColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                }
                            </div>

                            <!-- Info -->
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:0.9375rem;font-weight:600;color:var(--text-primary);">@ledger.MovementType</div>
                                <div style="font-size:0.8125rem;color:var(--text-secondary);margin-top:2px;">@ledger.PostedAt.ToString("MMM dd, yyyy HH:mm")</div>
                                @if (!string.IsNullOrEmpty(ledger.Notes))
                                {
                                    <div style="font-size:0.8125rem;color:var(--text-secondary);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@ledger.Notes</div>
                                }
                            </div>

                            <!-- Qty & Balance -->
                            <div style="text-align:right;flex-shrink:0;">
                                <div style="font-size:1rem;font-weight:700;color:@qtyColor;">
                                    @(isPositive ? "+" : "")@ledger.Qty.ToString("N2")
                                </div>
                                <div style="font-size:0.75rem;color:var(--text-secondary);margin-top:2px;">
                                    Balance: <strong style="color:var(--text-primary);">@ledger.BalanceAfter.ToString("N2")</strong>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
