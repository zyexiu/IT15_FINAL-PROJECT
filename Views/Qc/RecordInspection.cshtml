@model SnackFlowMES.Models.QcResult
@{
    ViewData["Title"] = "Record QC Inspection";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var workOrder = ViewBag.WorkOrder as SnackFlowMES.Models.WorkOrder;
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Record QC Inspection</h1>
        <p class="dash-page-subtitle">Work Order: @workOrder?.WoNumber - @workOrder?.Item?.ItemName</p>
    </div>
    <a href="/WorkOrder/Details/@Model.WorkOrderId" class="dash-btn dash-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Work Order
    </a>
</div>

@if (TempData["Warning"] != null)
{
    <div class="dash-alert dash-alert--warning">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        @TempData["Warning"]
    </div>
}

<!-- Work Order Summary -->
<div class="dash-panel" style="margin-bottom:24px;">
    <div class="dash-panel-header">
        <h2 class="dash-panel-title">Work Order Summary</h2>
    </div>
    <div style="padding:20px;">
        <div class="dash-detail-grid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));">
            <div class="dash-detail-row">
                <span class="dash-detail-label">WO Number</span>
                <span class="dash-detail-value dash-detail-value--mono">@workOrder?.WoNumber</span>
            </div>
            <div class="dash-detail-row">
                <span class="dash-detail-label">Product</span>
                <span class="dash-detail-value">@workOrder?.Item?.ItemName</span>
            </div>
            <div class="dash-detail-row">
                <span class="dash-detail-label">Planned Qty</span>
                <span class="dash-detail-value">@workOrder?.PlannedQty.ToString("N2") @workOrder?.UnitOfMeasure</span>
            </div>
            <div class="dash-detail-row">
                <span class="dash-detail-label">Actual Qty</span>
                <span class="dash-detail-value dash-detail-value--highlight">@workOrder?.ActualQty.ToString("N2") @workOrder?.UnitOfMeasure</span>
            </div>
            <div class="dash-detail-row">
                <span class="dash-detail-label">Production Line</span>
                <span class="dash-detail-value">@(workOrder?.ProductionLine ?? "—")</span>
            </div>
            <div class="dash-detail-row">
                <span class="dash-detail-label">Completed Date</span>
                <span class="dash-detail-value">@workOrder?.ActualEnd?.ToString("MMM dd, yyyy")</span>
            </div>
        </div>
    </div>
</div>

<div class="dash-panel" style="width:min(1120px,calc(100vw - 340px));margin:0 auto 24px;padding:24px 26px;">
    <form asp-action="RecordInspection" method="post">
        <input type="hidden" asp-for="WorkOrderId" />
        <div asp-validation-summary="ModelOnly" class="dash-alert dash-alert--error"></div>

        <h2 style="font-size:1.125rem;font-weight:600;margin:0 0 20px 0;color:var(--text-primary);">Inspection Results</h2>

        <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px 20px;margin-bottom:20px;">
            <div class="dash-form-group">
                <label asp-for="Result" class="dash-form-label">Inspection Result *</label>
                <select asp-for="Result" asp-items="ViewBag.Results" class="dash-form-input" required>
                    <option value="">-- Select Result --</option>
                </select>
                <span asp-validation-for="Result" class="dash-form-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="CheckType" class="dash-form-label">Check Type</label>
                <select asp-for="CheckType" asp-items="ViewBag.CheckTypes" class="dash-form-input">
                    <option value="">-- Select Check Type --</option>
                </select>
                <span asp-validation-for="CheckType" class="dash-form-error"></span>
            </div>

            <div class="dash-form-group">
                <label asp-for="SampleQty" class="dash-form-label">Sample Quantity</label>
                <input asp-for="SampleQty" type="number" step="0.01" class="dash-form-input" placeholder="0.00" />
                <span asp-validation-for="SampleQty" class="dash-form-error"></span>
                <small class="dash-form-help">Quantity inspected from the batch</small>
            </div>

            <div class="dash-form-group">
                <label asp-for="DefectQty" class="dash-form-label">Defect Quantity</label>
                <input asp-for="DefectQty" type="number" step="0.01" class="dash-form-input" placeholder="0.00" />
                <span asp-validation-for="DefectQty" class="dash-form-error"></span>
                <small class="dash-form-help">Quantity found defective</small>
            </div>

            <div class="dash-form-group" style="grid-column:1/-1;">
                <label asp-for="Disposition" class="dash-form-label">Disposition *</label>
                <select asp-for="Disposition" asp-items="ViewBag.Dispositions" class="dash-form-input" required>
                    <option value="">-- Select Disposition --</option>
                </select>
                <span asp-validation-for="Disposition" class="dash-form-error"></span>
                <small class="dash-form-help">What should happen to this batch?</small>
            </div>

            <div class="dash-form-group" style="grid-column:1/-1;">
                <label asp-for="Notes" class="dash-form-label">Inspection Notes</label>
                <textarea asp-for="Notes" rows="4" class="dash-form-input" placeholder="Detailed inspection findings, observations, and recommendations..."></textarea>
                <span asp-validation-for="Notes" class="dash-form-error"></span>
            </div>
        </div>

        <div style="display:flex;gap:12px;margin-top:24px;padding-top:24px;border-top:1px solid var(--border-color);">
            <button type="submit" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Submit Inspection
            </button>
            <a href="/WorkOrder/Details/@Model.WorkOrderId" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        // Auto-fill disposition based on result
        document.querySelector('select[name="Result"]').addEventListener('change', function() {
            const dispositionSelect = document.querySelector('select[name="Disposition"]');
            if (this.value === 'Pass') {
                dispositionSelect.value = 'Accept';
            } else if (this.value === 'Fail') {
                dispositionSelect.value = 'Reject';
            } else if (this.value === 'ConditionalPass') {
                dispositionSelect.value = 'Rework';
            }
        });
    </script>
}
