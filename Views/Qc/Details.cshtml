@model SnackFlowMES.Models.QcResult
@{
    ViewData["Title"] = $"QC Inspection QC-{Model.QcResultId:D4}";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header" style="display:flex;justify-content:space-between;align-items:center;gap:16px;width:100%;">
    <div>
        <h1 class="dash-page-title">QC Inspection QC-@Model.QcResultId.ToString("D4")</h1>
        <p class="dash-page-subtitle">@Model.WorkOrder?.WoNumber - @Model.WorkOrder?.Item?.ItemName</p>
    </div>
    <a asp-action="Index" class="dash-btn dash-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to List
    </a>
</div>

<div style="display:flex;justify-content:flex-end;gap:8px;margin-bottom:24px;">
    @if (User.IsInRole("Admin") || User.IsInRole("QC"))
    {
        <a asp-action="Edit" asp-route-id="@Model.QcResultId" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Edit
        </a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

<div class="dash-detail-grid">
    <!-- Inspection Results -->
    <div class="dash-detail-card">
        <div class="dash-detail-header">
            <h2 class="dash-detail-title">Inspection Results</h2>
            @{
                var resultClass = Model.Result switch
                {
                    "Pass" => "dash-badge--completed",
                    "Fail" => "dash-badge--cancelled",
                    "ConditionalPass" => "dash-badge--released",
                    _ => ""
                };
            }
            <span class="dash-badge @resultClass">@Model.Result</span>
        </div>

        <div class="dash-detail-body">
            <div class="dash-detail-row">
                <span class="dash-detail-label">Work Order</span>
                <span class="dash-detail-value">
                    <a href="/WorkOrder/Details/@Model.WorkOrderId">@Model.WorkOrder?.WoNumber</a>
                </span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Product</span>
                <span class="dash-detail-value">@Model.WorkOrder?.Item?.ItemName</span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Check Type</span>
                <span class="dash-detail-value">@(Model.CheckType ?? "—")</span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Sample Quantity</span>
                <span class="dash-detail-value">@(Model.SampleQty?.ToString("N2") ?? "—")</span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Defect Quantity</span>
                <span class="dash-detail-value">@(Model.DefectQty?.ToString("N2") ?? "—")</span>
            </div>

            @if (Model.SampleQty.HasValue && Model.DefectQty.HasValue && Model.SampleQty.Value > 0)
            {
                var defectRate = (Model.DefectQty.Value / Model.SampleQty.Value) * 100;
                <div class="dash-detail-row">
                    <span class="dash-detail-label">Defect Rate</span>
                    <span class="dash-detail-value" style="font-weight:600;color:@(defectRate > 5 ? "#EF4444" : "#10B981");">
                        @defectRate.ToString("F2")%
                    </span>
                </div>
            }

            <div class="dash-detail-row">
                <span class="dash-detail-label">Disposition</span>
                <span class="dash-detail-value">
                    @{
                        var dispositionColor = Model.Disposition switch
                        {
                            "Accept" => "#10B981",
                            "Rework" => "#F59E0B",
                            "Reject" => "#EF4444",
                            _ => "#6B7280"
                        };
                    }
                    <span style="font-weight:600;color:@dispositionColor;">@(Model.Disposition ?? "—")</span>
                </span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="dash-detail-row" style="grid-column:1/-1;">
                    <span class="dash-detail-label">Inspection Notes</span>
                    <span class="dash-detail-value" style="white-space:pre-wrap;">@Model.Notes</span>
                </div>
            }
        </div>
    </div>

    <!-- Inspector Information -->
    <div class="dash-detail-card">
        <div class="dash-detail-header">
            <h2 class="dash-detail-title">Inspector Information</h2>
        </div>

        <div class="dash-detail-body">
            <div class="dash-detail-row">
                <span class="dash-detail-label">Inspected By</span>
                <span class="dash-detail-value">@Model.InspectedBy?.FullName</span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Inspected Date</span>
                <span class="dash-detail-value">@Model.InspectedAt.ToString("MMMM dd, yyyy")</span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Inspected Time</span>
                <span class="dash-detail-value">@Model.InspectedAt.ToString("h:mm tt")</span>
            </div>
        </div>
    </div>

    <!-- Work Order Summary -->
    <div class="dash-detail-card" style="grid-column:1/-1;">
        <div class="dash-detail-header">
            <h2 class="dash-detail-title">Work Order Summary</h2>
        </div>

        <div class="dash-detail-body">
            <div class="dash-detail-row">
                <span class="dash-detail-label">Production Line</span>
                <span class="dash-detail-value">@(Model.WorkOrder?.ProductionLine ?? "—")</span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Planned Quantity</span>
                <span class="dash-detail-value">@Model.WorkOrder?.PlannedQty.ToString("N2") @Model.WorkOrder?.UnitOfMeasure</span>
            </div>

            <div class="dash-detail-row">
                <span class="dash-detail-label">Actual Quantity</span>
                <span class="dash-detail-value dash-detail-value--highlight">@Model.WorkOrder?.ActualQty.ToString("N2") @Model.WorkOrder?.UnitOfMeasure</span>
            </div>

            @if (Model.WorkOrder != null && Model.WorkOrder.PlannedQty > 0)
            {
                var variance = Model.WorkOrder.ActualQty - Model.WorkOrder.PlannedQty;
                var variancePercent = (variance / Model.WorkOrder.PlannedQty) * 100;
                <div class="dash-detail-row">
                    <span class="dash-detail-label">Variance</span>
                    <span class="dash-detail-value" style="font-weight:600;color:@(variance >= 0 ? "#10B981" : "#EF4444");">
                        @(variance >= 0 ? "+" : "")@variance.ToString("N2") (@variancePercent.ToString("F1")%)
                    </span>
                </div>
            }

            <div class="dash-detail-row">
                <span class="dash-detail-label">Completed Date</span>
                <span class="dash-detail-value">@Model.WorkOrder?.ActualEnd?.ToString("MMMM dd, yyyy h:mm tt")</span>
            </div>
        </div>
    </div>
</div>
