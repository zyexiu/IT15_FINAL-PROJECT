@model IEnumerable<SnackFlowMES.Models.Notification>
@{
    var panelTitle = ViewBag.PanelTitle as string ?? "Recent Notifications";
    var showAll = ViewBag.ShowAll as bool? ?? false;
    var limit = ViewBag.Limit as int? ?? 5;
    var notifications = showAll ? Model : Model.Take(limit);
}

<div class="dash-panel">
    <div class="dash-panel-header">
        <h2 class="dash-panel-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            @panelTitle
        </h2>
        @if (!showAll && Model.Any())
        {
            <a href="/Notification" class="dash-panel-action">View all →</a>
        }
    </div>

    @if (!notifications.Any())
    {
        <div class="dash-empty" style="padding:40px 20px;">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <p style="margin-top:12px;color:#6B7280;">No notifications</p>
        </div>
    }
    else
    {
        <div class="dash-notification-list">
            @foreach (var notification in notifications)
            {
                var priorityColor = notification.Priority switch
                {
                    "Critical" => "#EF4444",
                    "High" => "#F59E0B",
                    "Medium" => "#3B82F6",
                    _ => "#6B7280"
                };

                var typeIcon = notification.Type switch
                {
                    "LowStock" => "<path d='M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/><line x1='12' y1='9' x2='12' y2='13'/><line x1='12' y1='17' x2='12.01' y2='17'/>",
                    "MaterialRequest" => "<path d='M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'/><polyline points='9 22 9 12 15 12 15 22'/>",
                    "ProductionComplete" => "<path d='M22 11.08V12a10 10 0 1 1-5.93-9.14'/><polyline points='22 4 12 14.01 9 11.01'/>",
                    "QCFailed" => "<circle cx='12' cy='12' r='10'/><line x1='15' y1='9' x2='9' y2='15'/><line x1='9' y1='9' x2='15' y2='15'/>",
                    "QCPassed" => "<path d='M22 11.08V12a10 10 0 1 1-5.93-9.14'/><polyline points='22 4 12 14.01 9 11.01'/>",
                    _ => "<path d='M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9'/><path d='M13.73 21a2 2 0 0 1-3.46 0'/>"
                };

                var timeAgo = GetTimeAgo(notification.CreatedAt);

                <a href="@(notification.ActionUrl ?? "/Notification")" class="dash-notification-item @(notification.IsRead ? "dash-notification-item--read" : "")" data-notification-id="@notification.NotificationId">
                    <div class="dash-notification-icon" style="background:@priorityColor;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">@Html.Raw(typeIcon)</svg>
                    </div>
                    <div class="dash-notification-content">
                        <div class="dash-notification-header">
                            <span class="dash-notification-title">@notification.Title</span>
                            <span class="dash-notification-time">@timeAgo</span>
                        </div>
                        <p class="dash-notification-message">@notification.Message</p>
                        @if (notification.Priority == "Critical" || notification.Priority == "High")
                        {
                            <span class="dash-notification-priority" style="color:@priorityColor;">@notification.Priority Priority</span>
                        }
                    </div>
                    @if (!notification.IsRead)
                    {
                        <div class="dash-notification-unread"></div>
                    }
                </a>
            }
        </div>
    }
</div>

@functions {
    string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;

        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays}d ago";
        
        return dateTime.ToString("MMM dd");
    }
}

<style>
.dash-notification-list {
    display: flex;
    flex-direction: column;
}

.dash-notification-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid #E5E7EB;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.2s;
    position: relative;
}

.dash-notification-item:hover {
    background-color: #F9FAFB;
}

.dash-notification-item:last-child {
    border-bottom: none;
}

.dash-notification-item--read {
    opacity: 0.6;
}

.dash-notification-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: white;
}

.dash-notification-content {
    flex: 1;
    min-width: 0;
}

.dash-notification-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 4px;
}

.dash-notification-title {
    font-weight: 600;
    font-size: 0.875rem;
    color: #111827;
}

.dash-notification-time {
    font-size: 0.75rem;
    color: #6B7280;
    white-space: nowrap;
}

.dash-notification-message {
    font-size: 0.875rem;
    color: #4B5563;
    margin: 0;
    line-height: 1.5;
}

.dash-notification-priority {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    margin-top: 4px;
}

.dash-notification-unread {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #3B82F6;
    flex-shrink: 0;
    margin-top: 4px;
}
</style>
