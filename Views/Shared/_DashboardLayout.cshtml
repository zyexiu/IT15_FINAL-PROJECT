@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SnackFlowMES.Models
@using SnackFlowMES.Services
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser>   UserManager
@inject SnackFlowMES.Data.ApplicationDbContext DbContext
@{
    var user     = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? User.Identity?.Name ?? "User";
    var roles    = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
    var role     = roles.FirstOrDefault() ?? "User";
    var initials = string.Concat(fullName.Split(' ').Take(2).Select(w => w[0])).ToUpper();

    // Resolve tenant ID for current user
    var tenantId = user?.TenantId;
    if (user != null && string.IsNullOrWhiteSpace(tenantId))
    {
        // Admin: their tenant ID is their own user ID
        tenantId = roles.Contains("Admin") ? user.Id : user.Id;
    }

    // Get role-based menu
    var menuItems = RoleMenuService.GetMenuForRole(role);
    
    // Add badge to Material Request menu item for Admin showing pending count
    if (role == "Admin" && user != null)
    {
        var pendingCount = await DbContext.MaterialRequests
            .Where(mr => mr.Status == "Pending" && (mr.TenantId == tenantId || string.IsNullOrEmpty(mr.TenantId)))
            .CountAsync();
        
        var materialRequestItem = menuItems.FirstOrDefault(m => m.Controller == "MaterialRequest");
        if (materialRequestItem != null && pendingCount > 0)
        {
            materialRequestItem.Badge = pendingCount.ToString();
            materialRequestItem.BadgeColor = "danger";
        }
    }
    
    var sections = menuItems.GroupBy(m => m.Section).ToList();

    // Active nav detection
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string Nav(string c) =>
        ctrl.Equals(c, StringComparison.OrdinalIgnoreCase) ? "dash-nav-link--active" : "";


    // Icon mapping
    string GetIcon(string iconName) => iconName switch
    {
        "dashboard" => "<rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/>",
        "file-text" => "<path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/><line x1=\"16\" y1=\"13\" x2=\"8\" y2=\"13\"/><line x1=\"16\" y1=\"17\" x2=\"8\" y2=\"17\"/>",
        "calendar" => "<rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/>",
        "layers" => "<polygon points=\"12 2 3 7 12 12 21 7 12 2\"/><polyline points=\"3 12 12 17 21 12\"/><polyline points=\"3 17 12 22 21 17\"/>",
        "package" => "<path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"/>",
        "bar-chart" => "<line x1=\"18\" y1=\"20\" x2=\"18\" y2=\"10\"/><line x1=\"12\" y1=\"20\" x2=\"12\" y2=\"4\"/><line x1=\"6\" y1=\"20\" x2=\"6\" y2=\"14\"/>",
        "users" => "<path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/>",
        "settings" => "<circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M12 1v6m0 6v6\"/><path d=\"M17.2 4.8l-4.2 4.2m0 6l4.2 4.2\"/><path d=\"M23 12h-6m-6 0H1\"/><path d=\"M19.8 19.8l-4.2-4.2m0-6l4.2-4.2\"/>",
        "check-circle" => "<path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/>",
        "activity" => "<polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"/>",
        "alert-circle" => "<circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"/><line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"/>",
        "shopping-cart" => "<circle cx=\"9\" cy=\"21\" r=\"1\"/><circle cx=\"20\" cy=\"21\" r=\"1\"/><path d=\"M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6\"/>",
        _ => "<circle cx=\"12\" cy=\"12\" r=\"10\"/>"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] — SnackFlow MES</title>
    <script>
        (function () {
            const key = 'snackflow-theme';
            let theme = 'light';

            try {
                const stored = localStorage.getItem(key);
                if (stored === 'light' || stored === 'dark') {
                    theme = stored;
                } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    theme = 'dark';
                }
            } catch {
                theme = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            document.documentElement.dataset.theme = theme;
            document.documentElement.style.colorScheme = theme;
        })();
    </script>
    <link rel="icon" type="image/png" href="~/images/snackflow-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/work-orders-table.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
    <!-- Chart.js for analytics (local copy - no CDN dependency) -->
    <script src="~/js/chart.umd.min.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dash-body">

    <!-- ══ SIDEBAR ══════════════════════════════════════════ -->
    <aside class="dash-sidebar" id="dash-sidebar" role="navigation" aria-label="Main navigation">

        <!-- Brand -->
        <div class="dash-sidebar-brand">
            <img src="~/images/snackflow-logo.png" alt="SnackFlow" class="dash-sidebar-logo" />
            <div class="dash-sidebar-brand-text">
                <span class="dash-brand-name">Snack<span class="dash-brand-accent">Flow</span></span>
                <span class="dash-brand-sub">MES</span>
            </div>
        </div>

        <!-- Dynamic Role-Based Navigation -->
        @foreach (var section in sections)
        {
            <div class="dash-nav-section-label" style="@(section.Key != "MAIN MENU" ? "margin-top:24px;" : "")">@(section.Key)</div>
            <nav>
                <ul class="dash-nav-list" role="list">
                    @foreach (var item in section)
                    {
                        <li>
                            <a href="/@item.Controller/@item.Action" class="dash-nav-link @Nav(item.Controller)">
                                <svg class="dash-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">@Html.Raw(GetIcon(item.Icon))</svg>
                                <span>@item.Title</span>
                                @if (!string.IsNullOrEmpty(item.Badge))
                                {
                                    <span class="dash-nav-badge dash-nav-badge--@(item.BadgeColor ?? "primary")">@item.Badge</span>
                                }
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }

        <!-- Sidebar footer -->
        <div class="dash-sidebar-footer">
            <div class="dash-sidebar-user">
                <div class="dash-avatar" aria-hidden="true">@initials</div>
                <div class="dash-sidebar-user-info">
                    <span class="dash-sidebar-user-name">@fullName</span>
                    <span class="dash-sidebar-user-role">@role</span>
                </div>
            </div>
        </div>

    </aside>

    <!-- ══ MAIN AREA ═════════════════════════════════════════ -->
    <div class="dash-main" id="dash-main">

        <!-- Topbar -->
        <header class="dash-topbar" role="banner">
            <div class="dash-topbar-left">
                <!-- Mobile sidebar toggle -->
                <button class="dash-sidebar-toggle" id="dash-sidebar-toggle" aria-label="Toggle sidebar" aria-expanded="false" aria-controls="dash-sidebar">
                    <span></span><span></span><span></span>
                </button>
                <!-- Desktop sidebar toggle -->
                <button class="dash-sidebar-toggle--desktop" id="dash-sidebar-toggle-desktop" aria-label="Toggle sidebar" aria-expanded="true" aria-controls="dash-sidebar" title="Collapse/Expand sidebar">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8h12M6 16h12"/><path d="M3 12l3-3m0 6l-3-3m18 0l-3 3m0-6l3 3"/></svg>
                </button>
                <div class="dash-topbar-title">@ViewData["Title"]</div>
            </div>

            <div class="dash-topbar-right">
                <!-- Theme toggle -->
                <button type="button" class="theme-toggle dash-theme-toggle" data-theme-toggle>
                    <svg class="theme-toggle__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-theme-icon></svg>
                </button>

                <!-- Profile Dropdown -->
                <div class="dash-profile-dropdown">
                    <button class="dash-profile-btn" id="dash-profile-btn" aria-expanded="false" aria-haspopup="true">
                        <div class="dash-profile-avatar">@initials</div>
                        <div class="dash-profile-info">
                            <span class="dash-profile-name">@fullName</span>
                            <span class="dash-profile-role">@role</span>
                        </div>
                        <svg class="dash-profile-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>

                    <div class="dash-profile-menu" id="dash-profile-menu" role="menu" aria-hidden="true">
                        <div class="dash-profile-menu-header">
                            <div class="dash-profile-avatar-large">@initials</div>
                            <div>
                                <div class="dash-profile-menu-name">@fullName</div>
                                <div class="dash-profile-menu-email">@(user?.Email ?? "")</div>
                            </div>
                        </div>
                        <div class="dash-profile-menu-divider"></div>
                        <a href="@Url.Action("Profile", "Account")" class="dash-profile-menu-item" role="menuitem">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span>My Profile</span>
                        </a>
                        <a href="@Url.Action("ChangePassword", "Account")" class="dash-profile-menu-item" role="menuitem">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <span>Change Password</span>
                        </a>
                        <div class="dash-profile-menu-divider"></div>
                        <form asp-action="Logout" asp-controller="Account" method="post" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dash-profile-menu-item dash-profile-menu-item--danger" role="menuitem">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                <span>Logout</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page content -->
        <main class="dash-content" role="main">
            @RenderBody()
        </main>

    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function() {
            const mobileToggle   = document.getElementById('dash-sidebar-toggle');
            const desktopToggle  = document.getElementById('dash-sidebar-toggle-desktop');
            const sidebar        = document.getElementById('dash-sidebar');
            const COLLAPSED_KEY  = 'snackflow-sidebar-collapsed';
            const OPEN_KEY       = 'snackflow-sidebar-open';

            // Initialize sidebar state from localStorage
            function initSidebar() {
                const isMobile = window.innerWidth < 1024;
                
                if (isMobile) {
                    // Mobile: use open/closed state
                    const wasOpen = localStorage.getItem(OPEN_KEY) === 'true';
                    if (wasOpen) {
                        sidebar.classList.add('dash-sidebar--open');
                        mobileToggle.setAttribute('aria-expanded', 'true');
                    }
                } else {
                    // Desktop: use collapsed state (default collapsed)
                    const shouldBeCollapsed = localStorage.getItem(COLLAPSED_KEY) !== 'false';
                    if (shouldBeCollapsed) {
                        sidebar.classList.add('dash-sidebar--collapsed');
                        desktopToggle.setAttribute('aria-expanded', 'false');
                    }
                }
            }

            // Mobile toggle handler
            mobileToggle.addEventListener('click', () => {
                const isOpen = sidebar.classList.toggle('dash-sidebar--open');
                mobileToggle.setAttribute('aria-expanded', String(isOpen));
                localStorage.setItem(OPEN_KEY, String(isOpen));
            });

            // Desktop toggle handler
            desktopToggle.addEventListener('click', () => {
                const isCollapsed = sidebar.classList.toggle('dash-sidebar--collapsed');
                desktopToggle.setAttribute('aria-expanded', String(!isCollapsed));
                localStorage.setItem(COLLAPSED_KEY, String(isCollapsed));
            });

            // Close sidebar on outside click (mobile)
            document.addEventListener('click', e => {
                if (window.innerWidth < 1024 &&
                    !sidebar.contains(e.target) &&
                    !mobileToggle.contains(e.target)) {
                    sidebar.classList.remove('dash-sidebar--open');
                    mobileToggle.setAttribute('aria-expanded', 'false');
                    localStorage.setItem(OPEN_KEY, 'false');
                }
            });

            // Handle window resize to switch between mobile/desktop modes
            let resizeTimeout;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    const isMobile = window.innerWidth < 1024;
                    if (isMobile) {
                        sidebar.classList.remove('dash-sidebar--collapsed');
                    } else {
                        sidebar.classList.remove('dash-sidebar--open');
                        const shouldBeCollapsed = localStorage.getItem(COLLAPSED_KEY) !== 'false';
                        sidebar.classList.toggle('dash-sidebar--collapsed', shouldBeCollapsed);
                    }
                }, 250);
            });

            // Initialize on load
            initSidebar();
        })();

        // Profile Dropdown
        (function() {
            const profileBtn = document.getElementById('dash-profile-btn');
            const profileMenu = document.getElementById('dash-profile-menu');

            if (!profileBtn || !profileMenu) return;

            function openMenu() {
                profileMenu.classList.add('dash-profile-menu--open');
                profileMenu.setAttribute('aria-hidden', 'false');
                profileBtn.setAttribute('aria-expanded', 'true');
            }

            function closeMenu() {
                profileMenu.classList.remove('dash-profile-menu--open');
                profileMenu.setAttribute('aria-hidden', 'true');
                profileBtn.setAttribute('aria-expanded', 'false');
            }

            function toggleMenu() {
                const isOpen = profileMenu.classList.contains('dash-profile-menu--open');
                isOpen ? closeMenu() : openMenu();
            }

            // Toggle on button click
            profileBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                toggleMenu();
            });

            // Close on outside click
            document.addEventListener('click', (e) => {
                if (!profileBtn.contains(e.target) && !profileMenu.contains(e.target)) {
                    closeMenu();
                }
            });

            // Close on Escape key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    closeMenu();
                }
            });
        })();

        // Mark notification as read
        window.markAsRead = function(notificationId) {
            fetch(`/Notification/MarkAsRead/${notificationId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            }).catch(err => console.error('Failed to mark notification as read:', err));
        };

        // Mark notification as read and navigate
        window.markAsReadAndNavigate = function(notificationId, url) {
            fetch(`/Notification/MarkAsRead/${notificationId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(() => {
                // Navigate to the URL
                window.location.href = url;
            })
            .catch(err => {
                console.error('Failed to mark notification as read:', err);
                // Navigate anyway
                window.location.href = url;
            });
        };

        // Mark all notifications as read
        window.markAllAsRead = function() {
            fetch('/Notification/MarkAllAsRead', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            }).then(() => {
                location.reload();
            }).catch(err => console.error('Failed to mark all as read:', err));
        };
    </script>
    <style>
        /* Notification Dropdown Styles */
        .dash-notification-dropdown {
            position: relative;
        }

        .dash-notification-btn {
            position: relative;
            width: 40px;
            height: 40px;
            border-radius: 8px;
            border: none;
            background: transparent;
            color: var(--text-secondary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .dash-notification-btn:hover {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        .dash-notification-badge {
            position: absolute;
            top: 6px;
            right: 6px;
            background: #EF4444;
            color: white;
            font-size: 0.625rem;
            font-weight: 700;
            padding: 2px 5px;
            border-radius: 10px;
            min-width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }

        .dash-notification-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 380px;
            max-width: calc(100vw - 32px);
            background: var(--bg-primary);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s;
            z-index: 1000;
            max-height: 500px;
            display: flex;
            flex-direction: column;
        }

        .dash-notification-menu--open {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dash-notification-menu-header {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .dash-notification-menu-header h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .dash-notification-mark-all {
            background: none;
            border: none;
            color: #3B82F6;
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 4px;
            transition: background 0.2s;
        }

        .dash-notification-mark-all:hover {
            background: var(--bg-secondary);
        }

        .dash-notification-menu-list {
            overflow-y: auto;
            max-height: 400px;
        }

        .dash-notification-menu-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 12px 20px;
            border-bottom: 1px solid var(--border-color);
            text-decoration: none;
            color: inherit;
            transition: background 0.2s;
            position: relative;
        }

        .dash-notification-menu-item:hover {
            background: var(--bg-secondary);
        }

        .dash-notification-menu-item:last-child {
            border-bottom: none;
        }

        .dash-notification-menu-item--read {
            opacity: 0.6;
        }

        .dash-notification-menu-icon {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: white;
        }

        .dash-notification-menu-content {
            flex: 1;
            min-width: 0;
        }

        .dash-notification-menu-title {
            font-weight: 600;
            font-size: 0.875rem;
            color: var(--text-primary);
            margin-bottom: 2px;
        }

        .dash-notification-menu-message {
            font-size: 0.8125rem;
            color: var(--text-secondary);
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .dash-notification-menu-unread {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #3B82F6;
            flex-shrink: 0;
            margin-top: 4px;
        }

        .dash-notification-menu-empty {
            padding: 40px 20px;
            text-align: center;
            color: var(--text-secondary);
        }

        .dash-notification-menu-empty svg {
            opacity: 0.3;
            margin-bottom: 8px;
        }

        .dash-notification-menu-empty p {
            margin: 0;
            font-size: 0.875rem;
        }

        .dash-notification-menu-footer {
            padding: 12px 20px;
            border-top: 1px solid var(--border-color);
            text-align: center;
        }

        .dash-notification-menu-footer a {
            color: #3B82F6;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            transition: color 0.2s;
        }

        .dash-notification-menu-footer a:hover {
            color: #2563EB;
        }

        @@media (max-width: 768px) {
            .dash-notification-menu {
                width: 320px;
            }
        }
    </style>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
