@model IEnumerable<SnackFlowMES.ViewModels.UserListViewModel>
@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">User Management</h1>
        <p class="dash-page-subtitle">Manage system users and roles</p>
    </div>
    <a asp-action="Create" class="dash-btn dash-btn--primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add New User
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--error">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        @TempData["Error"]
    </div>
}

@if (!Model.Any())
{
    <div class="dash-empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <h3>No users found</h3>
        <p>Add your first user to get started.</p>
        <a asp-action="Create" class="dash-btn dash-btn--primary" style="margin-top:16px;">Add New User</a>
    </div>
}
else
{
    <div class="dash-table-container">
        <table class="dash-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="dash-user-cell">
                                <div class="dash-avatar dash-avatar--sm">
                                    @string.Concat(user.FullName.Split(' ').Take(2).Select(w => w[0])).ToUpper()
                                </div>
                                <div class="dash-user-meta">
                                    <div class="dash-user-name">@user.FullName</div>
                                    <div class="dash-user-username">@user.UserName</div>
                                </div>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>
                            <span class="dash-badge dash-badge--@(user.Role == "Admin" ? "danger" : "secondary")">@user.Role</span>
                        </td>
                        <td>
                            <span class="dash-badge dash-badge--@(user.IsActive ? "success" : "secondary")">@(user.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <div class="dash-user-actions">
                                <a asp-action="Edit" asp-route-id="@user.UserId" class="dash-user-action dash-user-action--edit" title="Edit user" aria-label="Edit user">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    <span>Edit</span>
                                </a>

                                <form asp-action="ToggleStatus" asp-route-id="@user.UserId" method="post" style="display:inline;margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dash-user-action dash-user-action--@(user.IsActive ? "danger" : "success")" title="@(user.IsActive ? "Deactivate" : "Activate") user" aria-label="@(user.IsActive ? "Deactivate" : "Activate") user" onclick="return confirm('@(user.IsActive ? "Deactivate" : "Activate") this user?');">
                                        @if (user.IsActive)
                                        {
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                            <span>Deactivate</span>
                                        }
                                        else
                                        {
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                            <span>Activate</span>
                                        }
                                    </button>
                                </form>

                                @if (!user.IsActive)
                                {
                                    <form asp-action="Delete" asp-route-id="@user.UserId" method="post" style="display:inline;margin:0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dash-user-action dash-user-action--delete" title="Permanently delete user" aria-label="Permanently delete user" onclick="return confirm('⚠️ WARNING: This will permanently delete this user from the system and database. This action cannot be undone!\n\nAre you sure you want to delete @user.FullName?');">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                            <span>Delete</span>
                                        </button>
                                    </form>
                                }

                                <button type="button" class="dash-user-action dash-user-action--neutral" title="Reset password" aria-label="Reset password" onclick="showResetPasswordModal('@user.UserId', '@user.FullName')">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                    <span>Reset Password</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Reset Password Modal -->
<div id="resetPasswordModal" class="dash-modal" style="display:none;">
    <div class="dash-modal-overlay" onclick="closeResetPasswordModal()"></div>
    <div class="dash-modal-content">
        <div class="dash-modal-header">
            <h3 class="dash-modal-title">Reset Password</h3>
            <button type="button" class="dash-modal-close" onclick="closeResetPasswordModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form asp-action="ResetPassword" method="post" id="resetPasswordForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="resetUserId" />
            <div class="dash-modal-body">
                <p class="dash-modal-copy">Reset password for <strong id="resetUserName"></strong></p>
                <div class="dash-form-group">
                    <label class="dash-label">New Password</label>
                    <div class="dash-input-wrap">
                        <input type="password" name="newPassword" id="newPassword" class="dash-input" required minlength="6" placeholder="Enter new password" />
                        <button type="button" class="dash-input-toggle" aria-label="Show password" data-target="newPassword" onclick="togglePassword(this)">
                            <svg class="icon-eye" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="icon-eye-off" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                                <path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z" />
                                <line x1="2" y1="2" x2="22" y2="22" />
                            </svg>
                        </button>
                    </div>
                    <small class="dash-hint">Minimum 6 characters</small>
                    <div id="passwordMismatchTop" class="dash-form-error" style="display:none;">Passwords do not match</div>
                </div>

                <div class="dash-form-group">
                    <label class="dash-label">Confirm New Password</label>
                    <div class="dash-input-wrap">
                        <input type="password" name="confirmPassword" id="confirmPassword" class="dash-input" required minlength="6" placeholder="Re-enter new password" />
                        <button type="button" class="dash-input-toggle" aria-label="Show password" data-target="confirmPassword" onclick="togglePassword(this)">
                            <svg class="icon-eye" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="icon-eye-off" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                                <path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z" />
                                <line x1="2" y1="2" x2="22" y2="22" />
                            </svg>
                        </button>
                    </div>
                    <small class="dash-hint">Both passwords must match</small>
                    <div id="passwordMismatch" class="dash-form-error" style="display:none;">Passwords do not match</div>
                </div>
            </div>
            <div class="dash-modal-footer">
                <button type="button" class="dash-btn dash-btn--secondary" onclick="closeResetPasswordModal()">Cancel</button>
                <button type="submit" id="resetPasswordSubmit" class="dash-btn dash-btn--primary">Reset Password</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showResetPasswordModal(userId, userName) {
            document.getElementById('resetUserId').value = userId;
            document.getElementById('resetUserName').textContent = userName;
            document.getElementById('resetPasswordModal').style.display = 'flex';
        }

        function closeResetPasswordModal() {
            document.getElementById('resetPasswordModal').style.display = 'none';
            document.getElementById('resetPasswordForm').reset();
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeResetPasswordModal();
            }
        });

        // Toggle password visibility for inputs using the data-target attribute
        function togglePassword(btn) {
            var targetId = btn.getAttribute('data-target');
            var input = document.getElementById(targetId);
            if (!input) return;
            var showing = input.type === 'text';
            if (!showing) {
                input.type = 'text';
                btn.classList.add('is-visible');
                btn.setAttribute('aria-label', 'Hide password');
                btn.setAttribute('aria-pressed', 'true');
            } else {
                input.type = 'password';
                btn.classList.remove('is-visible');
                btn.setAttribute('aria-label', 'Show password');
                btn.setAttribute('aria-pressed', 'false');
            }
        }

        // Validate password fields on submit (show messages for both fields)
        (function() {
            var form = document.getElementById('resetPasswordForm');
            if (!form) return;
            form.addEventListener('submit', function(e) {
                var p1 = document.getElementById('newPassword');
                var p2 = document.getElementById('confirmPassword');
                var err = document.getElementById('passwordMismatch');
                var errTop = document.getElementById('passwordMismatchTop');

                // clear previous custom validity messages
                if (p1) p1.setCustomValidity('');
                if (p2) p2.setCustomValidity('');
                if (err) err.style.display = 'none';
                if (errTop) errTop.style.display = 'none';

                var blocked = false;

                // Check required
                if (!p1 || !p2) return; // nothing to do
                if (!p1.value) {
                    p1.setCustomValidity('Please fill in this field.');
                    p1.reportValidity();
                    blocked = true;
                }
                if (!p2.value) {
                    p2.setCustomValidity('Please fill in this field.');
                    p2.reportValidity();
                    blocked = true;
                }
                if (blocked) {
                    e.preventDefault();
                    return false;
                }

                // Check match
                if (p1.value !== p2.value) {
                    var msg = 'Passwords do not match';
                    p1.setCustomValidity(msg);
                    p2.setCustomValidity(msg);
                    if (err) err.style.display = 'block';
                    if (errTop) errTop.style.display = 'block';
                    // show browser bubble on the confirm field
                    p2.reportValidity();
                    e.preventDefault();
                    return false;
                }

                // allow submit
            });
        })();
    </script>
}
