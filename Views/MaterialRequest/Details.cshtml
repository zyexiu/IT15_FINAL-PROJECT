@model SnackFlowMES.Models.MaterialRequest
@{
    ViewData["Title"] = $"Material Request MR-{Model.RequestId:D4}";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Material Request MR-@Model.RequestId.ToString("D4")</h1>
        <p class="dash-page-subtitle">@Model.Item?.ItemName</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        <a asp-action="Index" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to List
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--error">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        @TempData["Error"]
    </div>
}

<div class="dash-grid-2">
    <!-- Left column: Request Details -->
    <div class="dash-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Request Details</h2>
            @{
                var statusClass = Model.Status switch
                {
                    "Pending" => "draft",
                    "Approved" => "released",
                    "Fulfilled" => "completed",
                    "Rejected" => "cancelled",
                    _ => ""
                };
            }
            <span class="dash-badge dash-badge--@statusClass">@Model.Status</span>
        </div>
        <div class="dash-detail-grid">
            <div class="dash-detail-item">
                <span class="dash-detail-label">Item</span>
                <span class="dash-detail-value">
                    <a href="/Inventory/Details/@Model.ItemId" style="color:#3B82F6;text-decoration:none;font-weight:600;">@Model.Item?.ItemName</a>
                </span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Item Code</span>
                <span class="dash-detail-value">@Model.Item?.ItemCode</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Requested Quantity</span>
                <span class="dash-detail-value" style="font-weight:600;color:#3B82F6;">@Model.RequestedQty.ToString("N2") @Model.UnitOfMeasure</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Reason</span>
                <span class="dash-detail-value">@Model.Reason</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Priority</span>
                <span class="dash-detail-value">
                    @{
                        var priorityColor = Model.Priority switch
                        {
                            "Critical" => "#EF4444",
                            "High" => "#F59E0B",
                            "Medium" => "#3B82F6",
                            _ => "#6B7280"
                        };
                    }
                    <span style="display:inline-block;padding:4px 10px;border-radius:12px;font-size:0.75rem;font-weight:600;color:white;background:@priorityColor;">
                        @Model.Priority
                    </span>
                </span>
            </div>

            @if (Model.RequiredByDate.HasValue)
            {
                <div class="dash-detail-item">
                    <span class="dash-detail-label">Required By</span>
                    <span class="dash-detail-value">@Model.RequiredByDate.Value.ToString("MMM dd, yyyy")</span>
                </div>
            }

            <div class="dash-detail-item">
                <span class="dash-detail-label">Requested By</span>
                <span class="dash-detail-value">@Model.RequestedBy?.FullName</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Requested Date</span>
                <span class="dash-detail-value">@Model.RequestedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div style="margin-top:20px;padding-top:20px;border-top:1px solid #E4E9EF;">
                <span class="dash-detail-label">Notes</span>
                <p style="margin-top:8px;color:#6B7A8D;line-height:1.6;">@Model.Notes</p>
            </div>
        }
    </div>

    <!-- Right column: Timeline & Status -->
    <div>
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Request Timeline
                </h2>
            </div>

            <div class="dash-timeline">
                <div class="dash-timeline-item">
                    <div class="dash-timeline-dot" style="background:#3B82F6;"></div>
                    <div class="dash-timeline-content">
                        <div class="dash-timeline-title">Requested</div>
                        <div class="dash-timeline-time">@Model.RequestedAt.ToString("MMM dd, HH:mm")</div>
                        <div class="dash-timeline-user">by @Model.RequestedBy?.FullName</div>
                    </div>
                </div>

                @if (Model.ApprovedByUserId != null)
                {
                    var approvalColor = Model.Status == "Rejected" ? "#EF4444" : "#10B981";
                    var approvalLabel = Model.Status == "Rejected" ? "Rejected" : "Approved";
                    
                    <div class="dash-timeline-item">
                        <div class="dash-timeline-dot" style="background:@approvalColor;"></div>
                        <div class="dash-timeline-content">
                            <div class="dash-timeline-title">@approvalLabel</div>
                            <div class="dash-timeline-time">@Model.ApprovedAt?.ToString("MMM dd, HH:mm")</div>
                            <div class="dash-timeline-user">by @Model.ApprovedBy?.FullName</div>
                            @if (!string.IsNullOrEmpty(Model.ApprovalNotes))
                            {
                                <div style="margin-top:8px;padding:8px 12px;background:rgba(0,0,0,0.03);border-radius:6px;font-size:0.8125rem;color:#6B7A8D;line-height:1.5;">
                                    @Model.ApprovalNotes
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Model.Status == "Fulfilled")
                {
                    <div class="dash-timeline-item">
                        <div class="dash-timeline-dot" style="background:#10B981;"></div>
                        <div class="dash-timeline-content">
                            <div class="dash-timeline-title">Fulfilled</div>
                            <div class="dash-timeline-time">@Model.FulfilledAt?.ToString("MMM dd, HH:mm")</div>
                            <div style="margin-top:8px;font-size:0.875rem;color:#6B7A8D;">
                                Quantity: <strong style="color:#10B981;">@Model.FulfilledQty?.ToString("N2") @Model.UnitOfMeasure</strong>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Status Summary -->
            <div class="dash-summary-box" style="margin-top:20px;">
                <div class="dash-summary-row">
                    <span>Status</span>
                    <strong style="color:@(Model.Status == "Fulfilled" ? "#10B981" : Model.Status == "Rejected" ? "#EF4444" : Model.Status == "Approved" ? "#3B82F6" : "#F59E0B");">@Model.Status</strong>
                </div>
                <div class="dash-summary-row">
                    <span>Requested Qty</span>
                    <strong>@Model.RequestedQty.ToString("N2") @Model.UnitOfMeasure</strong>
                </div>
                @if (Model.Status == "Fulfilled" && Model.FulfilledQty.HasValue)
                {
                    <div class="dash-summary-row">
                        <span>Fulfilled Qty</span>
                        <strong style="color:#10B981;">@Model.FulfilledQty.Value.ToString("N2") @Model.UnitOfMeasure</strong>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Admin Actions -->
@if (User.IsInRole("Admin") && Model.Status == "Pending")
{
    <div class="dash-card" style="margin-top:24px;">
        <div class="dash-card-header">
            <h2 class="dash-card-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><shield width="18" height="18"/><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Admin Actions
            </h2>
        </div>

        <div style="padding:20px;">
            <form asp-action="Approve" method="post" style="margin-bottom:24px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.RequestId" />
                <div class="dash-form-group">
                    <label class="dash-form-label">Approval Notes (Optional)</label>
                    <textarea name="approvalNotes" rows="3" class="dash-form-input" placeholder="Add any notes about this approval..."></textarea>
                </div>
                <button type="submit" class="dash-btn dash-btn--primary dash-btn--full" onclick="return confirm('Approve this material request?');">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    Approve Request
                </button>
            </form>

            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.RequestId" />
                <div class="dash-form-group">
                    <label class="dash-form-label">Rejection Reason (Optional)</label>
                    <textarea name="approvalNotes" rows="3" class="dash-form-input" placeholder="Explain why this request is being rejected..."></textarea>
                </div>
                <button type="submit" class="dash-btn dash-btn--danger dash-btn--full" onclick="return confirm('Reject this material request?');">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    Reject Request
                </button>
            </form>
        </div>
    </div>
}

@if (User.IsInRole("Admin") && Model.Status == "Approved")
{
    <div class="dash-card" style="margin-top:24px;">
        <div class="dash-card-header">
            <h2 class="dash-card-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                Fulfill Request
            </h2>
        </div>

        <div style="padding:20px;">
            <form asp-action="Fulfill" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.RequestId" />
                <div class="dash-form-group">
                    <label class="dash-form-label">Fulfilled Quantity *</label>
                    <input type="number" name="fulfilledQty" step="0.01" value="@Model.RequestedQty" class="dash-form-input" required />
                    <small class="dash-form-help">Enter the actual quantity fulfilled (may differ from requested)</small>
                </div>
                <button type="submit" class="dash-btn dash-btn--primary dash-btn--full" onclick="return confirm('Mark this request as fulfilled?');">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    Mark as Fulfilled
                </button>
            </form>
        </div>
    </div>
}

<style>
.dash-grid-2 {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 24px;
    margin-bottom: 24px;
}

.dash-card {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
}

.dash-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 1px solid var(--border-color);
}

.dash-card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
}

.dash-detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    padding: 20px;
}

.dash-detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.dash-detail-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.dash-detail-value {
    font-size: 0.9375rem;
    color: var(--text-primary);
    font-weight: 500;
}

.dash-timeline {
    padding: 20px;
}

.dash-timeline-item {
    display: flex;
    gap: 12px;
    position: relative;
    padding-bottom: 24px;
}

.dash-timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 7px;
    top: 20px;
    bottom: 0;
    width: 2px;
    background: var(--border-color);
}

.dash-timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 2px;
}

.dash-timeline-content {
    flex: 1;
}

.dash-timeline-title {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-primary);
}

.dash-timeline-time {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 2px;
}

.dash-timeline-user {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-top: 2px;
}

.dash-summary-box {
    padding: 16px 20px;
    background: rgba(0, 0, 0, 0.02);
    border-top: 1px solid var(--border-color);
}

.dash-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    font-size: 0.875rem;
}

.dash-summary-row span {
    color: var(--text-secondary);
}

.dash-summary-row strong {
    color: var(--text-primary);
    font-weight: 600;
}

.dash-form-group {
    margin-bottom: 16px;
}

.dash-form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.dash-form-input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 0.875rem;
    color: var(--text-primary);
    background: var(--bg-primary);
    transition: all 0.2s;
}

.dash-form-input:focus {
    outline: none;
    border-color: #3B82F6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.dash-form-help {
    display: block;
    margin-top: 6px;
    font-size: 0.75rem;
    color: var(--text-secondary);
}

.dash-btn--full {
    width: 100%;
    justify-content: center;
}

.dash-btn--danger {
    background: #EF4444;
    color: white;
}

.dash-btn--danger:hover {
    background: #DC2626;
}

.dash-badge--draft {
    background: rgba(251, 191, 36, 0.12);
    color: #D97706;
}

.dash-badge--released {
    background: rgba(59, 130, 246, 0.12);
    color: #2563EB;
}

.dash-badge--completed {
    background: rgba(16, 185, 129, 0.12);
    color: #059669;
}

.dash-badge--cancelled {
    background: rgba(239, 68, 68, 0.12);
    color: #DC2626;
}

@@media (max-width: 1024px) {
    .dash-grid-2 {
        grid-template-columns: 1fr;
    }
}

@@media (max-width: 768px) {
    .dash-detail-grid {
        grid-template-columns: 1fr;
    }
}
</style>
