@model SnackFlowMES.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Change Password</h1>
        <p class="dash-page-subtitle">Update your account password</p>
    </div>
</div>

<div class="dash-form-container">
    <div class="dash-form-card">
        <div class="dash-form-header">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <div>
                <h2 class="dash-form-title">Change Your Password</h2>
                <p class="dash-form-subtitle">Enter your current password and choose a new one</p>
            </div>
        </div>

        <form asp-action="ChangePassword" method="post" class="dash-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="dash-alert dash-alert--error"></div>

            <!-- Current Password -->
            <div class="dash-form-group">
                <label asp-for="CurrentPassword" class="dash-form-label">Current Password</label>
                <div class="dash-form-input-group">
                    <input asp-for="CurrentPassword" type="password" class="dash-form-input" placeholder="Enter your current password" id="current-password" />
                    <button type="button" class="dash-form-input-icon" onclick="togglePassword('current-password', this)">
                        <svg class="eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="dash-form-error"></span>
            </div>

            <!-- New Password -->
            <div class="dash-form-group">
                <label asp-for="NewPassword" class="dash-form-label">New Password</label>
                <div class="dash-form-input-group">
                    <input asp-for="NewPassword" type="password" class="dash-form-input" placeholder="Enter your new password" id="new-password" />
                    <button type="button" class="dash-form-input-icon" onclick="togglePassword('new-password', this)">
                        <svg class="eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="dash-form-error"></span>
            </div>

            <!-- Confirm Password -->
            <div class="dash-form-group">
                <label asp-for="ConfirmPassword" class="dash-form-label">Confirm New Password</label>
                <div class="dash-form-input-group">
                    <input asp-for="ConfirmPassword" type="password" class="dash-form-input" placeholder="Confirm your new password" id="confirm-password" />
                    <button type="button" class="dash-form-input-icon" onclick="togglePassword('confirm-password', this)">
                        <svg class="eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="dash-form-error"></span>
            </div>

            <!-- Password Requirements -->
            <div class="dash-password-requirements">
                <div class="dash-password-requirements-title">Password must contain:</div>
                <ul class="dash-password-requirements-list">
                    <li>At least 8 characters</li>
                    <li>One uppercase letter (A-Z)</li>
                    <li>One lowercase letter (a-z)</li>
                    <li>One number (0-9)</li>
                    <li>One special character (!@@#$%^&*)</li>
                </ul>
            </div>

            <!-- Actions -->
            <div class="dash-form-actions">
                <button type="submit" class="dash-btn dash-btn--primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Change Password
                </button>
                <a asp-action="Profile" class="dash-btn dash-btn--secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>

    <!-- Security Tips Card -->
    <div class="dash-form-card">
        <div class="dash-form-header">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
                <h2 class="dash-form-title">Security Tips</h2>
                <p class="dash-form-subtitle">Keep your account secure</p>
            </div>
        </div>

        <div class="dash-security-tips">
            <div class="dash-security-tip">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Use a unique password you don't use elsewhere</span>
            </div>
            <div class="dash-security-tip">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Avoid common words and personal information</span>
            </div>
            <div class="dash-security-tip">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Change your password regularly</span>
            </div>
            <div class="dash-security-tip">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Never share your password with anyone</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const showIcon = button.querySelector('.eye-show');
            const hideIcon = button.querySelector('.eye-hide');
            
            if (input.type === 'password') {
                input.type = 'text';
                showIcon.style.display = 'none';
                hideIcon.style.display = 'block';
            } else {
                input.type = 'password';
                showIcon.style.display = 'block';
                hideIcon.style.display = 'none';
            }
        }
    </script>
}
