@model SnackFlowMES.ViewModels.LoginViewModel
@{
    Layout = null; // standalone page — no outer layout
    ViewData["Title"] = "Sign In — SnackFlow MES";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/snackflow-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/snackflow.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <!-- Google reCAPTCHA v2 -->
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
</head>
<body class="auth-body">

    <div class="auth-bg" aria-hidden="true"></div>

    <div class="auth-card">

        <!-- Logo + brand -->
        <div class="auth-brand">
            <img src="~/images/snackflow-logo.png" alt="SnackFlow logo" class="auth-logo" />
            <div>
                <div class="auth-brand-name">Snack<span>Flow</span></div>
                <div class="auth-brand-sub">Manufacturing Execution System</div>
            </div>
        </div>

        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to your production dashboard</p>

        <!-- Validation summary -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert" role="alert">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <asp-validation-summary asp-validation-summary="All" class="auth-alert-text"></asp-validation-summary>
            </div>
        }

        <form asp-action="Login" asp-controller="Account" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="auth-field">
                <label asp-for="Username" class="auth-label">Username or Email</label>
                <div class="auth-input-wrap">
                    <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <input asp-for="Username" class="auth-input" placeholder="admin@snackflow.local" autocomplete="username" autofocus />
                </div>
                <span asp-validation-for="Username" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password" class="auth-label">Password</label>
                <div class="auth-input-wrap">
                    <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <input asp-for="Password" class="auth-input" placeholder="••••••••" autocomplete="current-password" id="auth-password" />
                    <button type="button" class="auth-eye" id="auth-eye-btn" aria-label="Toggle password visibility" tabindex="-1">
                        <svg id="eye-show" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg id="eye-hide" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="auth-validation"></span>
            </div>

            <label class="auth-remember">
                <input asp-for="RememberMe" type="checkbox" class="auth-checkbox" />
                <span>Remember me for 8 hours</span>
            </label>

            <button type="button" class="auth-submit" id="auth-submit-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Sign In
            </button>

            <!-- reCAPTCHA v2 Checkbox (hidden by default, appears after clicking Sign In) -->
            <div id="recaptcha-container" class="auth-recaptcha-container" style="display: none; opacity: 0;">
                <div class="g-recaptcha" 
                     data-sitekey="@ViewBag.RecaptchaSiteKey" 
                     data-theme="light" 
                     data-callback="onRecaptchaSuccess"
                     data-expired-callback="onRecaptchaExpired"
                     data-error-callback="onRecaptchaError"></div>
                <input type="hidden" asp-for="RecaptchaToken" id="recaptcha-response" />
            </div>
        </form>

        <!-- Sign up prompt (UI only) -->
        <div class="auth-signup-row" style="margin-top: 24px; padding-top: 20px; border-top: 2px solid #E4E9EF; text-align: center; display: block !important; visibility: visible !important;">
            <button type="button" id="show-signup" class="auth-link-btn" style="display: inline-block !important; visibility: visible !important; background: #FFF8F0; border: 2px solid #E87722; color: #0F1C26; font-size: 1rem; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: 600; transition: all 220ms;">Don't have an account? <strong style="color: #E87722; font-weight: 800;">Sign Up</strong></button>
        </div>

        <!-- Hidden sign-up area (UI only) -->
        <div class="auth-signup-area" id="auth-signup-area" aria-hidden="true" style="display:none;">
            <h2 class="auth-subtitle" style="margin-top:18px;margin-bottom:12px">Create an account</h2>
            <div class="auth-field">
                <label class="auth-label">Full name</label>
                <input type="text" class="auth-input" placeholder="Jane Doe" />
            </div>
            <div class="auth-field">
                <label class="auth-label">Email</label>
                <input type="email" class="auth-input" placeholder="you@company.com" />
            </div>
            <div class="auth-field">
                <label class="auth-label">Role</label>
                <select class="auth-select">
                    <option>Operator</option>
                    <option>Planner</option>
                    <option>Manager</option>
                </select>
            </div>
            <div class="auth-field">
                <label class="auth-label">Department</label>
                <select class="auth-select">
                    <option>Production</option>
                    <option>Quality</option>
                    <option>Inventory</option>
                </select>
            </div>
            <div class="auth-field">
                <label class="auth-label">Password</label>
                <input type="password" class="auth-input" placeholder="Create a password" />
            </div>
            <div style="display:flex;gap:12px;margin-top:8px;">
                <button type="button" class="auth-submit" id="auth-signup-btn">Sign Up</button>
                <button type="button" class="auth-link-btn" id="auth-signup-cancel">Cancel</button>
            </div>
        </div>

        <div class="auth-back">
            <a href="/" class="auth-back-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Back to landing page
            </a>
        </div>

    </div>

    <script>
        console.log('=== reCAPTCHA v2 Implementation ===');
        
        // Toggle password visibility
        const pwdInput = document.getElementById('auth-password');
        const eyeBtn   = document.getElementById('auth-eye-btn');
        const eyeShow  = document.getElementById('eye-show');
        const eyeHide  = document.getElementById('eye-hide');
        if (eyeBtn && pwdInput) {
            eyeBtn.addEventListener('click', function(e) {
                e.preventDefault();
                const isText = pwdInput.type === 'text';
                pwdInput.type = isText ? 'password' : 'text';
                if (eyeShow) eyeShow.style.display = isText ? '' : 'none';
                if (eyeHide) eyeHide.style.display = isText ? 'none' : '';
            });
        }

        // Get form elements
        const usernameInput = document.getElementById('Username');
        const passwordInput = document.getElementById('Password');
        const recaptchaContainer = document.getElementById('recaptcha-container');
        const submitBtn = document.getElementById('auth-submit-btn');
        const recaptchaResponseInput = document.getElementById('recaptcha-response');
        const loginForm = document.querySelector('form[action*="Login"]');
        
        let recaptchaShown = false;
        let recaptchaCompleted = false;

        console.log('Elements found:', {
            usernameInput: !!usernameInput,
            passwordInput: !!passwordInput,
            recaptchaContainer: !!recaptchaContainer,
            submitBtn: !!submitBtn,
            loginForm: !!loginForm
        });

        // Handle Sign In button click
        if (submitBtn) {
            submitBtn.addEventListener('click', function(e) {
                e.preventDefault();
                
                const usernameValue = usernameInput ? usernameInput.value.trim() : '';
                const passwordValue = passwordInput ? passwordInput.value.trim() : '';

                console.log('Sign In clicked - Username:', usernameValue, 'Password:', passwordValue ? '***' : '(empty)');

                // Validate fields
                if (!usernameValue) {
                    alert('Please enter your username or email.');
                    usernameInput.focus();
                    return;
                }

                if (!passwordValue) {
                    alert('Please enter your password.');
                    passwordInput.focus();
                    return;
                }

                // If reCAPTCHA not shown yet, show it
                if (!recaptchaShown) {
                    console.log('✅ Showing reCAPTCHA for the first time');
                    recaptchaContainer.style.display = 'flex';
                    setTimeout(() => {
                        recaptchaContainer.style.opacity = '1';
                    }, 10);
                    recaptchaShown = true;
                    
                    // Change button text to indicate waiting for reCAPTCHA
                    submitBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Complete reCAPTCHA';
                    return;
                }

                // If reCAPTCHA shown but not completed
                if (recaptchaShown && !recaptchaCompleted) {
                    console.log('❌ reCAPTCHA not completed yet');
                    alert('Please complete the reCAPTCHA verification.');
                    return;
                }

                // If reCAPTCHA completed, submit the form
                if (recaptchaCompleted) {
                    console.log('✅ reCAPTCHA completed - Submitting form');
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Signing in...';
                    loginForm.submit();
                }
            });
        }

        // reCAPTCHA callback when user completes the challenge
        window.onRecaptchaSuccess = function(token) {
            console.log('✅ reCAPTCHA completed successfully');
            recaptchaCompleted = true;
            if (recaptchaResponseInput) {
                recaptchaResponseInput.value = token;
            }
            
            // Change button back to "Sign In" and enable it
            if (submitBtn) {
                submitBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Sign In';
                submitBtn.style.opacity = '1';
            }
        };

        // reCAPTCHA expired callback
        window.onRecaptchaExpired = function() {
            console.log('⚠️ reCAPTCHA expired');
            recaptchaCompleted = false;
            if (recaptchaResponseInput) {
                recaptchaResponseInput.value = '';
            }
            if (submitBtn) {
                submitBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Complete reCAPTCHA';
            }
            alert('reCAPTCHA expired. Please verify again.');
        };

        // reCAPTCHA error callback
        window.onRecaptchaError = function() {
            console.log('❌ reCAPTCHA error');
            recaptchaCompleted = false;
            if (recaptchaResponseInput) {
                recaptchaResponseInput.value = '';
            }
            alert('reCAPTCHA error. Please try again.');
        };
        
        // Toggle sign-up area (UI only)
        const showSignupBtn = document.getElementById('show-signup');
        const signupArea = document.getElementById('auth-signup-area');
        const signupCancel = document.getElementById('auth-signup-cancel');
        
        if (showSignupBtn && signupArea) {
            showSignupBtn.addEventListener('click', function(e) {
                e.preventDefault();
                const isCurrentlyHidden = signupArea.style.display === 'none';
                if (isCurrentlyHidden) {
                    signupArea.style.display = 'block';
                    signupArea.removeAttribute('aria-hidden');
                    showSignupBtn.textContent = "Already have an account? Back to Sign In";
                } else {
                    signupArea.style.display = 'none';
                    signupArea.setAttribute('aria-hidden', 'true');
                    showSignupBtn.innerHTML = "Don't have an account? <strong>Sign Up</strong>";
                }
            });
        }
        
        if (signupCancel && signupArea) {
            signupCancel.addEventListener('click', function(e) {
                e.preventDefault();
                signupArea.style.display = 'none';
                signupArea.setAttribute('aria-hidden', 'true');
                showSignupBtn.innerHTML = "Don't have an account? <strong>Sign Up</strong>";
            });
        }
        
        console.log('✅ reCAPTCHA script initialized');
    </script>
</body>
</html>
