@model SnackFlowMES.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">My Profile</h1>
        <p class="dash-page-subtitle">Manage your account information</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success" style="max-width:800px;margin:0 auto 24px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

<div style="max-width:800px;margin:0 auto;">
    <div class="dash-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Profile Information
            </h2>
        </div>

        <form asp-action="Profile" method="post" style="padding:32px;">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="dash-alert dash-alert--error"></div>

            <!-- Full Name -->
            <div class="dash-form-group">
                <label asp-for="FullName" class="dash-form-label">Full Name</label>
                <input asp-for="FullName" class="dash-form-input" placeholder="Enter your full name" />
                <span asp-validation-for="FullName" class="dash-form-error"></span>
            </div>

            <!-- Username -->
            <div class="dash-form-group">
                <label asp-for="UserName" class="dash-form-label">Username</label>
                <input asp-for="UserName" class="dash-form-input" placeholder="Enter your username" />
                <span asp-validation-for="UserName" class="dash-form-error"></span>
                <small class="dash-form-help">Letters, numbers, hyphens, and underscores only</small>
            </div>

            <!-- Email -->
            <div class="dash-form-group">
                <label asp-for="Email" class="dash-form-label">Email Address</label>
                <input asp-for="Email" type="email" class="dash-form-input" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="dash-form-error"></span>
            </div>

            <!-- Role (Read-only) -->
            <div class="dash-form-group">
                <label class="dash-form-label">Role</label>
                <div style="padding:12px;background:rgba(59,130,246,0.05);border-radius:8px;border:1px solid rgba(59,130,246,0.2);">
                    <span style="display:inline-block;padding:4px 12px;border-radius:12px;font-size:0.875rem;font-weight:600;color:white;background:#3B82F6;">@Model.Role</span>
                </div>
                <small class="dash-form-help">Your role cannot be changed</small>
            </div>

            <!-- Account Created (Read-only) -->
            <div class="dash-form-group">
                <label class="dash-form-label">Member Since</label>
                <div style="padding:12px;background:rgba(0,0,0,0.02);border-radius:8px;border:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">
                    @Model.CreatedAt.ToString("MMMM dd, yyyy")
                </div>
            </div>

            <!-- Actions -->
            <div style="display:flex;gap:12px;justify-content:center;margin-top:32px;padding-top:24px;border-top:1px solid var(--border-color);">
                <button type="submit" class="dash-btn dash-btn--primary" style="min-width:160px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Save Changes
                </button>
                <a asp-action="Index" asp-controller="Dashboard" class="dash-btn dash-btn--secondary" style="min-width:160px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<style>
.dash-form-group {
    margin-bottom: 24px;
}

.dash-form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.dash-form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 0.9375rem;
    color: var(--text-primary);
    background: var(--bg-primary);
    transition: all 0.2s;
}

.dash-form-input:focus {
    outline: none;
    border-color: #3B82F6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.dash-form-help {
    display: block;
    margin-top: 6px;
    font-size: 0.8125rem;
    color: var(--text-secondary);
}

.dash-form-error {
    display: block;
    margin-top: 6px;
    font-size: 0.8125rem;
    color: #EF4444;
    font-weight: 500;
}

@@media (max-width: 768px) {
    .dash-card {
        margin: 0 -8px;
    }
    
    form {
        padding: 24px 16px !important;
    }
    
    .dash-form-group {
        margin-bottom: 20px;
    }
    
    div[style*="justify-content:center"] {
        flex-direction: column;
    }
    
    .dash-btn {
        width: 100%;
    }
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
