@model SnackFlowMES.ViewModels.PlanLineFormViewModel
@{
    ViewData["Title"] = "Edit Plan Line";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Edit Plan Line</h1>
        <p class="dash-page-subtitle">Update item in @ViewBag.PlanName</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        <a asp-action="Details" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Plan
        </a>
    </div>
</div>

<div class="dash-card">
    <form asp-action="EditLine" asp-controller="ProductionPlan" method="post" style="padding:28px;" novalidate>
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.PlanLineId)
        @Html.HiddenFor(m => m.PlanId)

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="dash-alert dash-alert--error" style="margin-bottom:24px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div>
                    <strong>Please correct the following errors:</strong>
                    <ul style="margin:8px 0 0 16px;padding:0;">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- Product -->
        <div class="wo-section-label">Product</div>
        <div class="dash-form-group">
            <label asp-for="ItemId" class="dash-label dash-label--required">Finished Good</label>
            <select asp-for="ItemId" asp-items="ViewBag.Items" class="dash-select" required>
                <option value="">-- Select Finished Good --</option>
            </select>
            <span asp-validation-for="ItemId" class="dash-error"></span>
        </div>

        <!-- Quantity -->
        <div class="wo-section-label">Quantity</div>
        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="PlannedQty" class="dash-label dash-label--required">Planned Quantity</label>
                <input asp-for="PlannedQty" class="dash-input" type="number" step="0.01" min="0.01" placeholder="0.00" required />
                <span asp-validation-for="PlannedQty" class="dash-error"></span>
            </div>
            <div class="dash-form-group">
                <label asp-for="UnitOfMeasure" class="dash-label dash-label--required">Unit of Measure</label>
                <select asp-for="UnitOfMeasure" class="dash-select" required>
                    <option value="">-- Select Unit --</option>
                    <option value="kg">kg</option>
                    <option value="g">g</option>
                    <option value="L">L</option>
                    <option value="pcs">pcs</option>
                    <option value="bag">bag</option>
                    <option value="box">box</option>
                    <option value="pack">pack</option>
                </select>
                <span asp-validation-for="UnitOfMeasure" class="dash-error"></span>
            </div>
        </div>

        <!-- Schedule -->
        <div class="wo-section-label">Schedule</div>
        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="ScheduledDate" class="dash-label dash-label--required">Scheduled Date</label>
                <input asp-for="ScheduledDate" class="dash-input" type="datetime-local" required />
                <span asp-validation-for="ScheduledDate" class="dash-error"></span>
            </div>
            <div class="dash-form-group">
                <label asp-for="ProductionLine" class="dash-label">Production Line</label>
                <input asp-for="ProductionLine" class="dash-input" placeholder="e.g., Line 1, Line A" maxlength="80" />
                <span asp-validation-for="ProductionLine" class="dash-error"></span>
                <small class="dash-hint">Optional: Assign to specific line</small>
            </div>
        </div>

        <!-- Additional Information -->
        <div class="wo-section-label">Additional Information</div>
        <div class="dash-form-group">
            <label asp-for="Notes" class="dash-label">Notes</label>
            <textarea asp-for="Notes" class="dash-textarea" rows="3" placeholder="Add any special instructions..." maxlength="300"></textarea>
            <span asp-validation-for="Notes" class="dash-error"></span>
            <small class="dash-hint">Optional: Special instructions (max 300 characters)</small>
        </div>

        <!-- Actions -->
        <div style="display:flex;gap:12px;margin-top:32px;padding-top:24px;border-top:1px solid var(--border-color);">
            <button type="submit" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Save Changes
            </button>
            <a asp-action="Details" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

<style>
.wo-section-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-secondary);
    padding-bottom: 12px;
    margin: 24px 0 4px 0;
    border-bottom: 1px solid var(--border-color);
}
.wo-section-label:first-of-type { margin-top: 0; }
.dash-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.dash-form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
.dash-label { font-size: 0.875rem; font-weight: 600; color: var(--text-primary); }
.dash-label--required::after { content: ' *'; color: #EF4444; }
.dash-input, .dash-select, .dash-textarea {
    padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px;
    font-size: 0.9375rem; color: var(--text-primary); background: var(--bg-primary);
    transition: border-color 0.2s, box-shadow 0.2s; width: 100%;
}
.dash-input:focus, .dash-select:focus, .dash-textarea:focus {
    outline: none; border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
}
.dash-textarea { resize: vertical; min-height: 80px; }
.dash-hint { font-size: 0.8125rem; color: var(--text-secondary); }
.dash-error { font-size: 0.8125rem; color: #EF4444; font-weight: 500; }
@@media (max-width: 768px) { .dash-form-row { grid-template-columns: 1fr; } }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
