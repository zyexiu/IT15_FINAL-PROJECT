@model SnackFlowMES.ViewModels.ProductionPlanFormViewModel
@{
    ViewData["Title"] = "Edit Production Plan";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <p>@TempData["Success"]</p>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--error">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>@TempData["Error"]</p>
    </div>
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Edit Production Plan</h1>
        <p class="dash-page-subtitle">Update production plan details</p>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap;margin-left:auto;">
        <a asp-action="Details" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Details
        </a>
    </div>
</div>

<div class="dash-card">
    <form asp-action="Edit" asp-controller="ProductionPlan" method="post" style="padding:28px;" id="productionPlanForm" novalidate>
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.PlanId)

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="dash-alert dash-alert--error" style="margin-bottom:24px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div>
                    <strong>Please correct the following errors:</strong>
                    <ul style="margin:8px 0 0 16px;padding:0;">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- Plan Information -->
        <div class="wo-section-label">Plan Information</div>
        <div class="dash-form-group">
            <label asp-for="PlanName" class="dash-label dash-label--required">Plan Name</label>
            <input asp-for="PlanName" class="dash-input" placeholder="e.g., Q2 Production Schedule" required maxlength="100" />
            <span asp-validation-for="PlanName" class="dash-error"></span>
            <small class="dash-hint">Enter a descriptive name for this production plan</small>
        </div>

        <!-- Schedule Duration -->
        <div class="wo-section-label">Schedule Duration</div>
        <div class="dash-form-row">
            <div class="dash-form-group">
                <label asp-for="PlanDateFrom" class="dash-label dash-label--required">Plan Start Date</label>
                <input asp-for="PlanDateFrom" class="dash-input" type="datetime-local" required />
                <span asp-validation-for="PlanDateFrom" class="dash-error"></span>
                <small class="dash-hint">When does this plan start?</small>
            </div>
            <div class="dash-form-group">
                <label asp-for="PlanDateTo" class="dash-label dash-label--required">Plan End Date</label>
                <input asp-for="PlanDateTo" class="dash-input" type="datetime-local" required />
                <span asp-validation-for="PlanDateTo" class="dash-error"></span>
                <small class="dash-hint">When does this plan end?</small>
            </div>
        </div>

        <!-- Status -->
        <div class="wo-section-label">Status</div>
        <div class="dash-form-group">
            <label asp-for="Status" class="dash-label dash-label--required">Status</label>
            <select asp-for="Status" class="dash-select" required>
                <option value="">-- Select Status --</option>
                <option value="Draft">Draft (Editable)</option>
                <option value="Approved">Approved (Ready)</option>
                <option value="InProgress">In Progress (Active)</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
            <span asp-validation-for="Status" class="dash-error"></span>
            <small class="dash-hint">Update the plan status</small>
        </div>

        <!-- Additional Information -->
        <div class="wo-section-label">Additional Information</div>
        <div class="dash-form-group">
            <label asp-for="Notes" class="dash-label">Notes</label>
            <textarea asp-for="Notes" class="dash-textarea" rows="4" placeholder="Add any special instructions, constraints, or notes..." maxlength="500"></textarea>
            <span asp-validation-for="Notes" class="dash-error"></span>
            <small class="dash-hint">Optional: Any special instructions or notes (max 500 characters)</small>
        </div>

        <!-- Actions -->
        <div style="display:flex;gap:12px;margin-top:32px;padding-top:24px;border-top:1px solid var(--border-color);">
            <button type="submit" class="dash-btn dash-btn--primary" id="submitBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Update Production Plan
            </button>
            <a asp-action="Details" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

<style>
.wo-section-label {
    font-size: 0.8125rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.6px; color: var(--text-secondary);
    padding-bottom: 12px; margin: 24px 0 4px 0;
    border-bottom: 1px solid var(--border-color);
}
.wo-section-label:first-of-type { margin-top: 0; }
.dash-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.dash-form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
.dash-label { font-size: 0.875rem; font-weight: 600; color: var(--text-primary); }
.dash-label--required::after { content: ' *'; color: #EF4444; }
.dash-input, .dash-select, .dash-textarea {
    padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px;
    font-size: 0.9375rem; color: var(--text-primary); background: var(--bg-primary);
    transition: border-color 0.2s, box-shadow 0.2s; width: 100%;
}
.dash-input:focus, .dash-select:focus, .dash-textarea:focus {
    outline: none; border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
}
.dash-textarea { resize: vertical; min-height: 100px; }
.dash-hint { font-size: 0.8125rem; color: var(--text-secondary); }
.dash-error { font-size: 0.8125rem; color: #EF4444; font-weight: 500; }
@@media (max-width: 768px) { .dash-form-row { grid-template-columns: 1fr; } }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('productionPlanForm');
            const submitBtn = document.getElementById('submitBtn');
            if (form && submitBtn) {
                form.addEventListener('submit', function (e) {
                    const planName = document.querySelector('[name="PlanName"]');
                    const from = document.querySelector('[name="PlanDateFrom"]');
                    const to = document.querySelector('[name="PlanDateTo"]');
                    const status = document.querySelector('[name="Status"]');
                    const errors = [];
                    if (!planName.value || planName.value.trim().length < 3) errors.push('Plan name must be at least 3 characters.');
                    if (!from.value) errors.push('Please select a plan start date.');
                    if (!to.value) errors.push('Please select a plan end date.');
                    if (!status.value) errors.push('Please select a status.');
                    if (from.value && to.value && new Date(to.value) <= new Date(from.value))
                        errors.push('Plan end date must be after the start date.');
                    if (errors.length > 0) { e.preventDefault(); alert('Please fix:\n\n' + errors.join('\n')); return; }
                    submitBtn.disabled = true; submitBtn.style.opacity = '0.6';
                });
            }
        });
    </script>
}
