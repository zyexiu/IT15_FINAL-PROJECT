@model SnackFlowMES.Models.ProductionPlan
@{
    ViewData["Title"] = Model.PlanName;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Success Message -->
@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <p>@TempData["Success"]</p>
    </div>
}

<!-- Error Message -->
@if (TempData["Error"] != null)
{
    <div class="dash-alert dash-alert--error">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>@TempData["Error"]</p>
    </div>
}

<!-- Warning Message -->
@if (TempData["Warning"] != null)
{
    <div class="dash-alert dash-alert--warning">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <p>@TempData["Warning"]</p>
    </div>
}

<!-- Info Message -->
@if (TempData["Info"] != null)
{
    <div class="dash-alert dash-alert--info">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <p>@TempData["Info"]</p>
    </div>
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">@Model.PlanName</h1>
        <p class="dash-page-subtitle">Production plan details</p>
    </div>
    <div style="display: flex; gap: 8px;">
        @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
        {
            <a asp-action="Edit" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--secondary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit Plan
            </a>
        }
        <a asp-action="Index" class="dash-btn dash-btn--secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to List
        </a>
    </div>
</div>

<div class="dash-grid-2">
    <!-- Left column: Plan Information -->
    <div class="dash-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Plan Information</h2>
            <span class="dash-badge dash-badge--@Model.Status.ToLower()">@Model.Status</span>
        </div>
        <div class="dash-detail-grid">
            <div class="dash-detail-item">
                <span class="dash-detail-label">Plan Name</span>
                <span class="dash-detail-value">@Model.PlanName</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Status</span>
                <span class="dash-detail-value">@Model.Status</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Start Date</span>
                <span class="dash-detail-value">@Model.PlanDateFrom.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">End Date</span>
                <span class="dash-detail-value">@Model.PlanDateTo.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Duration</span>
                <span class="dash-detail-value">@((Model.PlanDateTo - Model.PlanDateFrom).Days) days</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Plan Lines</span>
                <span class="dash-detail-value">@(Model.PlanLines?.Count ?? 0)</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Created By</span>
                <span class="dash-detail-value">@(Model.CreatedBy?.FullName ?? "—")</span>
            </div>
            <div class="dash-detail-item">
                <span class="dash-detail-label">Created At</span>
                <span class="dash-detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div style="margin-top:20px;padding-top:20px;border-top:1px solid #E4E9EF;">
                <span class="dash-detail-label">Notes</span>
                <p style="margin-top:8px;color:#6B7A8D;line-height:1.6;">@Model.Notes</p>
            </div>
        }
    </div>

    <!-- Right column: Timeline -->
    <div class="dash-card">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Timeline</h2>
        </div>
        <div class="dash-timeline">
            <div class="dash-timeline-item">
                <div class="dash-timeline-marker dash-timeline-marker--active"></div>
                <div class="dash-timeline-content">
                    <div class="dash-timeline-title">Plan Created</div>
                    <div class="dash-timeline-date">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                    <div class="dash-timeline-desc">By @(Model.CreatedBy?.FullName ?? "—")</div>
                </div>
            </div>
            <div class="dash-timeline-item">
                <div class="dash-timeline-marker @(Model.Status == "Approved" || Model.Status == "InProgress" || Model.Status == "Completed" ? "dash-timeline-marker--active" : "")"></div>
                <div class="dash-timeline-content">
                    <div class="dash-timeline-title">Plan Start</div>
                    <div class="dash-timeline-date">@Model.PlanDateFrom.ToString("MMM dd, yyyy")</div>
                    <div class="dash-timeline-desc">Scheduled start date</div>
                </div>
            </div>
            <div class="dash-timeline-item">
                <div class="dash-timeline-marker @(Model.Status == "Completed" ? "dash-timeline-marker--active" : "")"></div>
                <div class="dash-timeline-content">
                    <div class="dash-timeline-title">Plan End</div>
                    <div class="dash-timeline-date">@Model.PlanDateTo.ToString("MMM dd, yyyy")</div>
                    <div class="dash-timeline-desc">Scheduled end date</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Plan Lines -->
<div class="dash-card" style="margin-top:24px;">
    <div class="dash-card-header">
        <h2 class="dash-card-title">Plan Lines</h2>
        <div style="display: flex; gap: 8px; align-items: center;">
            <span class="dash-badge">@(Model.PlanLines?.Count ?? 0) items</span>
            @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
            {
                <a asp-action="AddLine" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--primary dash-btn--sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                    Add Line
                </a>
                @if (Model.PlanLines != null && Model.PlanLines.Any(l => l.Status == "Pending"))
                {
                    <form asp-action="GenerateWorkOrders" asp-route-id="@Model.PlanId" method="post" style="display: inline;" onsubmit="return confirm('Generate work orders from pending plan lines?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dash-btn dash-btn--success dash-btn--sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                            Generate Work Orders
                        </button>
                    </form>
                }
            }
        </div>
    </div>
    @if (Model.PlanLines != null && Model.PlanLines.Any())
    {
        <div class="dash-table-container">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Planned Quantity</th>
                        <th>Scheduled Date</th>
                        <th>Production Line</th>
                        <th>Status</th>
                        <th>Notes</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
                        {
                            <th style="width: 80px;">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.PlanLines.OrderBy(l => l.ScheduledDate))
                    {
                        <tr>
                            <td>
                                <div style="display:flex;flex-direction:column;gap:4px;">
                                    <span style="font-weight:600;color:#0F1C26;">@(line.Item?.ItemName ?? "—")</span>
                                    <span style="font-size:0.8125rem;color:#6B7A8D;">@(line.Item?.ItemCode ?? "—")</span>
                                </div>
                            </td>
                            <td>@line.PlannedQty.ToString("N2") @line.UnitOfMeasure</td>
                            <td>@line.ScheduledDate.ToString("MMM dd, yyyy")</td>
                            <td>@(line.ProductionLine ?? "—")</td>
                            <td>
                                <span class="dash-badge dash-badge--@line.Status.ToLower().Replace(" ", "")">
                                    @line.Status
                                </span>
                            </td>
                            <td>@(line.Notes ?? "—")</td>
                            @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
                            {
                                <td>
                                    @if (line.Status == "Pending")
                                    {
                                        <form asp-action="DeleteLine" asp-route-id="@line.PlanLineId" asp-route-planId="@Model.PlanId" method="post" style="display: inline;" onsubmit="return confirm('Delete this plan line?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dash-btn-icon dash-btn-icon--danger" title="Delete">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span style="color: #6B7A8D; font-size: 0.8125rem;">—</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="padding: 40px; text-align: center; color: #6B7A8D;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin: 0 auto 16px; opacity: 0.3;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
            <p style="margin: 0 0 16px; font-size: 1rem; font-weight: 500;">No plan lines yet</p>
            <p style="margin: 0 0 24px; font-size: 0.875rem;">Add items to this production plan to get started</p>
            @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
            {
                <a asp-action="AddLine" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                    Add First Line
                </a>
            }
        </div>
    }
</div>

<!-- Action Buttons -->
@if (User.IsInRole("Admin") || User.IsInRole("Planner"))
{
    <div class="dash-card" style="margin-top:24px;">
        <div class="dash-card-header">
            <h2 class="dash-card-title">Actions</h2>
        </div>
        <div style="padding: 20px; display: flex; gap: 12px; flex-wrap: wrap;">
            <form asp-action="Delete" asp-route-id="@Model.PlanId" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this production plan? This will also delete all plan lines.');">
                @Html.AntiForgeryToken()
                <button type="submit" class="dash-btn dash-btn--danger">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    Delete Plan
                </button>
            </form>
        </div>
    </div>
}
