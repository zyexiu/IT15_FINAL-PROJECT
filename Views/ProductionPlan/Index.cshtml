@model IEnumerable<SnackFlowMES.Models.ProductionPlan>
@{
    ViewData["Title"] = "Production Planning";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Production Planning</h1>
        <p class="dash-page-subtitle">Manage production schedules and plans</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
    {
        <a asp-action="Create" class="dash-btn dash-btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Create Production Plan
        </a>
    }
</div>

<!-- Status Filter -->
<div class="dash-filter-bar">
    <div class="dash-filter-group">
        <label class="dash-filter-label">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            Filter by Status:
        </label>
        <div class="dash-filter-buttons">
            @foreach (var statusOption in ViewBag.StatusOptions as List<string>)
            {
                var isActive = ViewBag.CurrentStatus == statusOption;
                <a asp-action="Index" asp-route-status="@statusOption" asp-route-search="@ViewBag.SearchTerm"
                   class="dash-filter-btn @(isActive ? "dash-filter-btn--active" : "")">
                    @statusOption
                </a>
            }
        </div>
    </div>
    @if (ViewBag.CurrentStatus != "All")
    {
        <a asp-action="Index" asp-route-search="@ViewBag.SearchTerm" class="dash-filter-clear">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Clear Filter
        </a>
    }
</div>

<!-- Search -->
<div class="dash-tabs-row" style="margin-top: 16px;">
    <form method="get" action="@Url.Action("Index")" class="dash-search-form">
        <input type="hidden" name="status" value="@ViewBag.CurrentStatus" />
        <div class="dash-search-input-wrap">
            <input type="text" name="search" placeholder="Search items" value="@ViewBag.SearchTerm" aria-label="Search production plans" />
            <button type="button" class="dash-search-clear @(string.IsNullOrEmpty(ViewBag.SearchTerm) ? "is-hidden" : "")" aria-label="Clear search" onclick="const input=this.parentElement.querySelector('input[name=search]'); input.value=''; this.form.submit();">×</button>
        </div>
        <button type="submit" class="dash-btn dash-btn--secondary dash-btn--sm">Search</button>
    </form>
</div>

@if (TempData["Success"] != null)
{
    <div class="dash-alert dash-alert--success">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        @TempData["Success"]
    </div>
}

@if (!Model.Any())
{
    <div class="dash-empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <h3>No production plans found</h3>
        <p>Create your first production plan to schedule manufacturing activities.</p>
        @if (User.IsInRole("Admin") || User.IsInRole("Planner"))
        {
            <a asp-action="Create" class="dash-btn dash-btn--primary" style="margin-top:16px;">
                Create Production Plan
            </a>
        }
    </div>
}
else
{
    <div class="dash-plan-grid">
        @foreach (var plan in Model)
        {
            var duration = (plan.PlanDateTo - plan.PlanDateFrom).Days;
            var lineCount = plan.PlanLines?.Count ?? 0;
            var isActive = plan.Status == "InProgress" || plan.Status == "Approved";

            <div class="dash-plan-card-enhanced @(isActive ? "dash-plan-card--active" : "")">
                <div class="dash-plan-card-header-enhanced">
                    <div class="dash-plan-icon dash-plan-icon--@plan.Status.ToLower()">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <span class="dash-badge dash-badge--@plan.Status.ToLower()">@plan.Status</span>
                </div>

                <div class="dash-plan-card-content">
                    <h3 class="dash-plan-card-title-enhanced">@plan.PlanName</h3>
                    <p class="dash-plan-card-date">
                        @plan.PlanDateFrom.ToString("MMM dd") - @plan.PlanDateTo.ToString("MMM dd, yyyy")
                    </p>
                </div>

                <div class="dash-plan-stats-grid">
                    <div class="dash-plan-stat-box">
                        <div class="dash-plan-stat-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div>
                            <div class="dash-plan-stat-value">@lineCount</div>
                            <div class="dash-plan-stat-label">Plan Lines</div>
                        </div>
                    </div>
                    <div class="dash-plan-stat-box">
                        <div class="dash-plan-stat-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        </div>
                        <div>
                            <div class="dash-plan-stat-value">@duration</div>
                            <div class="dash-plan-stat-label">Days</div>
                        </div>
                    </div>
                </div>

                <div class="dash-plan-meta-row">
                    <div class="dash-plan-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <span>@(plan.CreatedBy?.FullName ?? "—")</span>
                    </div>
                    <div class="dash-plan-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span>@plan.CreatedAt.ToString("MMM dd")</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(plan.Notes))
                {
                    <div class="dash-plan-notes">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                        <span>@plan.Notes</span>
                    </div>
                }

                <div class="dash-plan-card-footer-enhanced">
                    <a asp-action="Details" asp-route-id="@plan.PlanId" class="dash-btn dash-btn--secondary dash-btn--sm dash-btn--full">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        View Details
                    </a>
                </div>
            </div>
        }
    </div>
}
