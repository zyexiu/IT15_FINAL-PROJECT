@model SnackFlowMES.ViewModels.PlanLineFormViewModel
@{
    ViewData["Title"] = "Add Plan Line";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Add Plan Line</h1>
        <p class="dash-page-subtitle">Add item to @ViewBag.PlanName</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Plan
    </a>
</div>

<div class="dash-card">
    <form asp-action="AddLine" asp-controller="ProductionPlan" method="post" class="dash-form" novalidate>
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.PlanId)
        
        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="dash-alert dash-alert--error">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div>
                    <strong>Please correct the following errors:</strong>
                    <ul>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- Section 1: Item Selection -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">Product</legend>
            
            <div class="dash-form-group">
                <label asp-for="ItemId" class="dash-label dash-label--required"></label>
                <select asp-for="ItemId" asp-items="ViewBag.Items" class="dash-select" required>
                    <option value="">-- Select Finished Good --</option>
                </select>
                <span asp-validation-for="ItemId" class="dash-error"></span>
                <span class="dash-form-hint">Select the finished good to produce</span>
            </div>
        </fieldset>

        <!-- Section 2: Quantity -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">Quantity</legend>
            
            <div class="dash-form-row">
                <div class="dash-form-group">
                    <label asp-for="PlannedQty" class="dash-label dash-label--required"></label>
                    <input asp-for="PlannedQty" class="dash-input" type="number" step="0.01" min="0.01" placeholder="0.00" required />
                    <span asp-validation-for="PlannedQty" class="dash-error"></span>
                    <span class="dash-form-hint">How much to produce?</span>
                </div>

                <div class="dash-form-group">
                    <label asp-for="UnitOfMeasure" class="dash-label dash-label--required"></label>
                    <select asp-for="UnitOfMeasure" class="dash-select" required>
                        <option value="">-- Select Unit --</option>
                        <option value="kg">kg</option>
                        <option value="g">g</option>
                        <option value="L">L</option>
                        <option value="pcs">pcs</option>
                        <option value="bag">bag</option>
                        <option value="box">box</option>
                        <option value="pack">pack</option>
                    </select>
                    <span asp-validation-for="UnitOfMeasure" class="dash-error"></span>
                </div>
            </div>
        </fieldset>

        <!-- Section 3: Schedule -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">Schedule</legend>
            
            <div class="dash-form-row">
                <div class="dash-form-group">
                    <label asp-for="ScheduledDate" class="dash-label dash-label--required"></label>
                    <input asp-for="ScheduledDate" class="dash-input" type="datetime-local" required />
                    <span asp-validation-for="ScheduledDate" class="dash-error"></span>
                    <span class="dash-form-hint">When to produce this item?</span>
                </div>

                <div class="dash-form-group">
                    <label asp-for="ProductionLine" class="dash-label"></label>
                    <input asp-for="ProductionLine" class="dash-input" placeholder="e.g., Line 1, Line A" maxlength="80" />
                    <span asp-validation-for="ProductionLine" class="dash-error"></span>
                    <span class="dash-form-hint">Optional: Assign to specific line</span>
                </div>
            </div>
        </fieldset>

        <!-- Section 4: Notes -->
        <fieldset>
            <legend style="font-size: 14px; font-weight: 700; color: #0F1C26; margin-bottom: 16px;">Additional Information</legend>
            
            <div class="dash-form-group">
                <label asp-for="Notes" class="dash-label"></label>
                <textarea asp-for="Notes" class="dash-textarea" rows="3" placeholder="Add any special instructions..." maxlength="300"></textarea>
                <span asp-validation-for="Notes" class="dash-error"></span>
                <span class="dash-form-hint">Optional: Special instructions (max 300 characters)</span>
            </div>
        </fieldset>

        <!-- Form Actions -->
        <div class="dash-form-actions">
            <button type="submit" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                Add Plan Line
            </button>
            <a asp-action="Details" asp-route-id="@Model.PlanId" class="dash-btn dash-btn--secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
