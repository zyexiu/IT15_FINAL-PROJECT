@model SnackFlowMES.Models.DowntimeReport
@{
    ViewData["Title"] = "Downtime Report Details";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    
    var statusColor = Model.Status switch
    {
        "Open" => "#F59E0B",
        "Resolved" => "#10B981",
        "Escalated" => "#EF4444",
        _ => "#6B7280"
    };

    var durationHours = Model.DurationMinutes / 60.0;
    var durationDisplay = Model.DurationMinutes >= 60 
        ? $"{durationHours:F1} hours" 
        : $"{Model.DurationMinutes} minutes";
}

<div class="dash-page-header">
    <div>
        <h1 class="dash-page-title">Downtime Report #@Model.DowntimeId</h1>
        <p class="dash-page-subtitle">@Model.ProductionLine - @Model.Reason</p>
    </div>
    <div class="dash-page-actions">
        @if ((User.IsInRole("Admin") || User.IsInRole("Manager")) && Model.Status == "Open")
        {
            <a href="@Url.Action("Resolve", new { id = Model.DowntimeId })" class="dash-btn dash-btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                Resolve Issue
            </a>
        }
        <a href="@Url.Action("Index")" class="dash-btn dash-btn--secondary">Back to List</a>
    </div>
</div>

<div class="dash-row">
    <!-- Main Details -->
    <div class="dash-panel dash-panel--wide">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Downtime Details
            </h2>
            <span class="dash-badge" style="background:@statusColor;color:white;font-size:0.875rem;">
                @Model.Status
            </span>
        </div>

        <div class="dash-detail-grid">
            <div class="dash-detail-item">
                <span class="dash-detail-label">Work Order</span>
                <span class="dash-detail-value">
                    <a href="/WorkOrder/Details/@Model.WorkOrderId" style="color:#3B82F6;text-decoration:none;font-weight:600;">
                        @Model.WorkOrder?.WoNumber
                    </a>
                </span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Product</span>
                <span class="dash-detail-value">@Model.WorkOrder?.Item?.ItemName</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Production Line</span>
                <span class="dash-detail-value">@Model.ProductionLine</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Reason</span>
                <span class="dash-detail-value">
                    <span class="dash-reason-badge" style="background:@GetReasonColor(Model.Reason);">
                        @Model.Reason
                    </span>
                </span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Start Time</span>
                <span class="dash-detail-value">@Model.StartTime.ToString("MMM dd, yyyy HH:mm")</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">End Time</span>
                <span class="dash-detail-value">
                    @if (Model.EndTime.HasValue)
                    {
                        @Model.EndTime.Value.ToString("MMM dd, yyyy HH:mm")
                    }
                    else
                    {
                        <span style="color:#F59E0B;font-weight:600;">Ongoing</span>
                    }
                </span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Duration</span>
                <span class="dash-detail-value" style="font-weight:600;color:@(Model.DurationMinutes > 60 ? "#EF4444" : "#6B7280");">
                    @durationDisplay
                </span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Reported By</span>
                <span class="dash-detail-value">@Model.ReportedBy?.FullName</span>
            </div>

            <div class="dash-detail-item">
                <span class="dash-detail-label">Reported At</span>
                <span class="dash-detail-value">@Model.ReportedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>

        <!-- Description -->
        <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border-color);">
            <h3 style="font-size:0.875rem;font-weight:600;color:var(--text-primary);margin:0 0 12px 0;">Description</h3>
            <p style="margin:0;color:var(--text-secondary);line-height:1.6;white-space:pre-wrap;">@Model.Description</p>
        </div>

        <!-- Resolution (if resolved) -->
        @if (!string.IsNullOrEmpty(Model.Resolution))
        {
            <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border-color);">
                <h3 style="font-size:0.875rem;font-weight:600;color:var(--text-primary);margin:0 0 12px 0;">Resolution</h3>
                <p style="margin:0;color:var(--text-secondary);line-height:1.6;white-space:pre-wrap;">@Model.Resolution</p>
                
                <div style="margin-top:16px;display:flex;gap:24px;font-size:0.875rem;color:var(--text-secondary);">
                    <div>
                        <strong>Resolved By:</strong> @Model.ResolvedBy?.FullName
                    </div>
                    <div>
                        <strong>Resolved At:</strong> @Model.ResolvedAt?.ToString("MMM dd, yyyy HH:mm")
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Timeline & Actions -->
    <div class="dash-panel dash-panel--narrow">
        <div class="dash-panel-header">
            <h2 class="dash-panel-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Timeline
            </h2>
        </div>

        <div class="dash-timeline">
            <div class="dash-timeline-item">
                <div class="dash-timeline-dot" style="background:#3B82F6;"></div>
                <div class="dash-timeline-content">
                    <div class="dash-timeline-title">Reported</div>
                    <div class="dash-timeline-time">@Model.ReportedAt.ToString("MMM dd, HH:mm")</div>
                    <div class="dash-timeline-user">by @Model.ReportedBy?.FullName</div>
                </div>
            </div>

            @if (Model.ResolvedAt.HasValue)
            {
                <div class="dash-timeline-item">
                    <div class="dash-timeline-dot" style="background:#10B981;"></div>
                    <div class="dash-timeline-content">
                        <div class="dash-timeline-title">@Model.Status</div>
                        <div class="dash-timeline-time">@Model.ResolvedAt.Value.ToString("MMM dd, HH:mm")</div>
                        <div class="dash-timeline-user">by @Model.ResolvedBy?.FullName</div>
                    </div>
                </div>
            }
        </div>

        <!-- Impact Summary -->
        <div class="dash-summary-box" style="margin-top:20px;">
            <div class="dash-summary-row">
                <span>Total Downtime</span>
                <strong style="color:@(Model.DurationMinutes > 60 ? "#EF4444" : "#6B7280");">@durationDisplay</strong>
            </div>
            <div class="dash-summary-row">
                <span>Status</span>
                <strong style="color:@statusColor;">@Model.Status</strong>
            </div>
            @if (Model.EndTime.HasValue)
            {
                <div class="dash-summary-row">
                    <span>Resolution Time</span>
                    <strong>
                        @{
                            var resolutionTime = Model.ResolvedAt.HasValue 
                                ? (Model.ResolvedAt.Value - Model.ReportedAt).TotalHours 
                                : 0;
                        }
                        @resolutionTime.ToString("F1")h
                    </strong>
                </div>
            }
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--border-color);">
                <form asp-action="Delete" asp-route-id="@Model.DowntimeId" method="post" onsubmit="return confirm('Are you sure you want to delete this downtime report?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dash-btn dash-btn--danger" style="width:100%;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        Delete Report
                    </button>
                </form>
            </div>
        }
    </div>
</div>

@functions {
    string GetReasonColor(string reason)
    {
        return reason switch
        {
            "Machine Breakdown" => "#EF4444",
            "Material Shortage" => "#F59E0B",
            "Power Outage" => "#EF4444",
            "Maintenance" => "#3B82F6",
            "Changeover" => "#10B981",
            _ => "#6B7280"
        };
    }
}

<style>
.dash-detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    padding: 20px;
}

.dash-detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.dash-detail-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.dash-detail-value {
    font-size: 0.9375rem;
    color: var(--text-primary);
    font-weight: 500;
}

.dash-reason-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
}

.dash-timeline {
    padding: 20px;
}

.dash-timeline-item {
    display: flex;
    gap: 12px;
    position: relative;
    padding-bottom: 24px;
}

.dash-timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 7px;
    top: 20px;
    bottom: 0;
    width: 2px;
    background: var(--border-color);
}

.dash-timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 2px;
}

.dash-timeline-content {
    flex: 1;
}

.dash-timeline-title {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-primary);
}

.dash-timeline-time {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 2px;
}

.dash-timeline-user {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-top: 2px;
}

.dash-btn--danger {
    background: #EF4444;
    color: white;
}

.dash-btn--danger:hover {
    background: #DC2626;
}
</style>
